---
import BaseLayout from "../components/layout/BaseLayout.astro";
import EstimateModalNative from "../components/ui/EstimateModalNative.astro";
import { business } from "../data/business";

const galleryImages = [
  { src: "/assets/work-hero.webp", alt: "Arborist climbing pine tree for trimming in Denver" },
  { src: "/assets/work-1.webp", alt: "Large tree removal project in Denver neighborhood" },
  { src: "/assets/work-2.webp", alt: "Tree trimming and pruning work by Arbor Care crew" },
  { src: "/assets/work-3.webp", alt: "Professional tree service completed in Denver CO" },
  { src: "/assets/work-4.webp", alt: "Stump grinding and yard cleanup after tree removal" },
  { src: "/assets/work-5.webp", alt: "Hazardous tree removal near residential property" },
  { src: "/assets/work-6.webp", alt: "Land clearing and brush removal in Denver" },
  { src: "/assets/crew-action.webp", alt: "Arbor Care Tree Solutions crew at work" },
  { src: "/assets/crew-truck.webp", alt: "Arbor Care Tree Solutions service truck" },
];
---

<BaseLayout
  title="Our Work | Arbor Care Tree Solutions Denver CO"
  description="See photos of our tree removal, trimming, stump grinding, and arborist work across Denver CO. ISA-certified, 100+ five-star reviews. Call (303) 949-6818."
>
  <!-- HERO -->
  <section class="relative min-h-[500px] md:min-h-[60vh] flex items-center overflow-hidden">
    <picture>
      <source media="(max-width: 767px)" srcset="/assets/crew-truck-mobile.webp" width="800" height="450" />
      <img
        src="/assets/crew-truck.webp"
        alt="Arbor Care Tree Solutions work portfolio"
        class="absolute inset-0 h-full w-full object-cover"
        width="1920"
        height="1080"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
    </picture>
    <div class="absolute inset-0 bg-black/60"></div>
    <div class="container relative z-10 py-20 pb-28 md:py-28 text-center">
      <div class="mx-auto max-w-3xl">
        <h1 class="text-3xl font-bold text-white md:text-5xl leading-tight">
          Our Work
          <span class="block text-accent mt-2 text-2xl md:text-3xl">
            Denver Tree Service in Action
          </span>
        </h1>
        <p class="mx-auto mt-6 text-lg text-white/90 max-w-2xl">
          Browse photos from our tree removal, trimming, stump grinding, and arborist projects
          across the Denver metro area. Every job backed by ISA-certified expertise.
        </p>
        <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
          <a href={business.phoneTel} class="inline-flex items-center justify-center gap-2 rounded-md bg-accent px-8 py-4 text-base font-bold text-accent-foreground shadow-lg hover:bg-accent/90 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call {business.phone}
          </a>
          <EstimateModalNative className="inline-flex items-center justify-center gap-2 rounded-md bg-white/15 backdrop-blur border border-white/30 px-8 py-4 text-base font-bold text-white hover:bg-white/25 transition-colors">
            Get Free Estimate
          </EstimateModalNative>
        </div>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 z-10 border-t border-white/20">
      <div class="container flex flex-wrap items-center justify-center gap-x-8 gap-y-2 py-3 text-sm text-white/90">
        <span class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          <span class="font-medium">100+ Five-Star Reviews</span>
        </span>
        <span class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
          <span class="font-medium">ISA-Certified Arborists</span>
        </span>
        <span class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/></svg>
          <span class="font-medium">No Trip Charge</span>
        </span>
        <span class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          <span class="font-medium">Family Owned</span>
        </span>
      </div>
    </div>
  </section>

  <!-- GALLERY -->
  <section class="py-16 md:py-24">
    <div class="container">
      <h2 class="text-center text-2xl font-bold md:text-4xl">
        Recent Projects Across Denver
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-center text-muted-foreground">
        From emergency storm damage to routine pruning - here's a look at the work we do every day
        for Denver homeowners and businesses.
      </p>
      <div class="mt-12 columns-1 gap-4 sm:columns-2 lg:columns-3">
        {galleryImages.map((img) => (
          <a
            href={img.src}
            target="_blank"
            rel="noopener noreferrer"
            class="mb-4 block w-full overflow-hidden rounded-lg border border-border transition-transform hover:scale-[1.02]"
          >
            <img
              src={img.src}
              alt={img.alt}
              class="w-full h-auto object-cover"
              loading="lazy"
              width="600"
              height="400"
            />
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-24 bg-muted">
    <div class="container">
      <div class="mx-auto max-w-2xl rounded-xl border-2 border-accent/30 bg-card p-8 md:p-12 text-center">
        <h2 class="text-2xl font-bold md:text-3xl">
          Ready for Your Project?
        </h2>
        <p class="mt-4 text-muted-foreground leading-relaxed">
          Get a free, no-obligation estimate from our ISA-certified arborists.
          We'll come to your property, assess the job, and give you a firm quote — no trip charge.
        </p>
        <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
          <a href={business.phoneTel} class="inline-flex items-center justify-center gap-2 rounded-md bg-accent px-8 py-4 text-base font-bold text-accent-foreground shadow-lg hover:bg-accent/90 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            {business.phone}
          </a>
          <EstimateModalNative className="inline-flex items-center justify-center gap-2 rounded-md border border-input bg-background px-8 py-4 text-base font-bold text-foreground hover:bg-muted transition-colors">
            Request Free Estimate
          </EstimateModalNative>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
