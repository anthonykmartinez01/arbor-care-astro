---
import BaseLayout from "../components/layout/BaseLayout.astro";
import { business } from "../data/business";

const serviceSections = [
  {
    title: "Tree Trimming & Pruning",
    path: "/tree-trimming",
    cards: [
      { title: "Bush & Shrub Trimming", description: "Shape and maintain overgrown shrubs using proper technique that promotes healthy regrowth.", path: "/bush-shrub-trimming-denver-co" },
      { title: "Crown Reduction", description: "Reduce the size of an overgrown canopy while preserving the tree's structure and health.", path: "/crown-reduction-denver-co" },
      { title: "Deadwooding", description: "Remove dead, dying, or diseased limbs to eliminate fall hazards and prevent disease spread.", path: "/deadwooding-denver-co" },
    ],
  },
  {
    title: "Tree Removal",
    path: "/tree-removal",
    cards: [
      { title: "Emergency Tree Removal", description: "Tree down on your property? We answer 24/7 and dispatch fast.", path: "/emergency-tree-removal-denver-co" },
      { title: "Hazardous Tree Removal", description: "Safe removal of structurally compromised or dangerously positioned trees.", path: "/hazardous-tree-removal-denver-co" },
      { title: "Bush & Shrub Removal", description: "Full removal of overgrown or unwanted shrubs, including root ball extraction.", path: "/bush-shrub-removal-denver-co" },
    ],
  },
  {
    title: "Stump Grinding",
    path: "/stump-grinding-denver-co",
    cards: [
      { title: "Stump Removal", description: "Full root ball excavation for situations where grinding alone won't solve the problem.", path: "/stump-removal-denver-co" },
    ],
  },
  {
    title: "Arborist Services",
    path: "/arborist-service-denver-co",
    cards: [
      { title: "Tree Treatment", description: "Targeted treatments for insect infestations, disease, and nutrient deficiencies.", path: "/tree-treatment-denver-co" },
      { title: "Tree Health Assessment", description: "A full evaluation of your tree's structure, health, and risk level by an ISA-certified arborist.", path: "/tree-health-assessment-denver-co" },
      { title: "Tree Planting", description: "Species selection, proper planting technique, and soil prep for new trees.", path: "/tree-planting-denver-co" },
    ],
  },
  {
    title: "Firewood Supply",
    path: "/other-services",
    cards: [
      { title: "Seasoned Firewood for Sale", description: "Properly dried, split hardwood by the cord or face cord — ready to burn.", path: "/seasoned-firewood-denver-co" },
      { title: "Firewood Delivery", description: "We deliver and stack seasoned hardwood throughout the Denver metro.", path: "/firewood-delivery-denver-co" },
    ],
  },
  {
    title: "General Tree Services",
    path: "",
    cards: [
      { title: "Brush Chipping", description: "On-site chipping of branches and brush into mulch — fast cleanup for large volumes of debris.", path: "/brush-chipping-denver-co" },
      { title: "Land Clearing", description: "Full clearing of trees, brush, and stumps for construction, landscaping, or fire mitigation.", path: "/land-clearing-denver-co" },
    ],
  },
];
---

<BaseLayout
  title="Tree Service Services Denver CO | Complete Service List"
  description="Full list of tree services in Denver CO. Tree removal, trimming, stump grinding, arborist care & firewood. Licensed professionals, 24-hour emergency service."
>
  <!-- HERO -->
  <section class="relative min-h-[500px] md:min-h-[60vh] flex items-center overflow-hidden">
    <picture>
      <source media="(max-width: 767px)" srcset="/assets/hero-services-mobile.webp" width="800" height="450" />
      <img
        src="/assets/hero-services.webp"
        alt="Professional tree services in Denver Colorado"
        class="absolute inset-0 h-full w-full object-cover"
        width="1920"
        height="1080"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
    </picture>
    <div class="absolute inset-0 bg-black/60"></div>
    <div class="container relative z-10 py-20 pb-28 md:py-28 text-center">
      <div class="mx-auto max-w-3xl">
        <div class="mx-auto mb-6 inline-flex h-16 w-16 items-center justify-center rounded-full bg-accent/20">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 14V2"/><path d="M9 18.12 10 14H4.17a2 2 0 0 1-1.92-2.56l2.33-8A2 2 0 0 1 6.5 2H20a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-2.76"/><path d="m14 8-2 4h-3l-2.5 6.78a1 1 0 0 0 .91 1.22H12"/></svg>
        </div>
        <h1 class="text-3xl font-bold text-white md:text-5xl leading-tight">
          Tree Services in Denver, CO
          <span class="block text-accent mt-2 text-xl md:text-2xl">Full-Service Tree Care for Every Job</span>
        </h1>
        <p class="mx-auto mt-4 text-lg text-white/80">
          Find the service you need or call us — we'll figure it out together.
        </p>
        <div class="mt-8">
          <a
            href={business.phoneTel}
            class="inline-flex items-center justify-center gap-2 rounded-md bg-accent px-8 py-4 text-base font-bold text-accent-foreground shadow-lg hover:bg-accent/90 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call {business.phone}
          </a>
        </div>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 bg-primary/95 backdrop-blur-sm">
      <div class="container flex flex-wrap items-center justify-center gap-x-8 gap-y-2 py-3 text-sm text-primary-foreground">
        <span class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          <span class="font-medium">100+ Five-Star Reviews</span>
        </span>
        <span class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
          <span class="font-medium">ISA-Certified Arborists</span>
        </span>
        <span class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/></svg>
          <span class="font-medium">Free Estimates</span>
        </span>
        <span class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          <span class="font-medium">Available 24/7</span>
        </span>
      </div>
    </div>
  </section>

  <!-- OPENING -->
  <section class="py-12 md:py-16">
    <div class="container">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-lg leading-relaxed text-muted-foreground">
          If you know what you need, find it below and click through for details. If you're not sure — maybe a tree looks off, something came down in a storm, or you just want someone to take a look — call us at <a href={business.phoneTel} class="text-primary font-semibold hover:underline">{business.phone}</a>. We answer immediately and can help you figure out the right next step. Arbor Care Tree Solutions handles everything from routine trimming to emergency removals throughout Denver and the surrounding metro, 24 hours a day.
        </p>
      </div>
    </div>
  </section>

  <!-- SERVICE SECTIONS -->
  {serviceSections.map((section, idx) => {
    const isAlt = idx % 2 === 0;
    const gridClass = section.cards.length === 1 ? "max-w-md" : section.cards.length === 2 ? "sm:grid-cols-2" : "sm:grid-cols-2 lg:grid-cols-3";
    return (
      <section class={`py-12 md:py-16 ${isAlt ? "bg-muted" : ""}`}>
        <div class="container">
          <div class="flex items-center gap-3 mb-8">
            <h2 class="text-2xl font-bold md:text-3xl">{section.title}</h2>
            {section.path && (
              <a
                href={section.path}
                class="inline-flex items-center gap-1 text-sm font-semibold text-primary hover:underline whitespace-nowrap"
              >
                View All <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
              </a>
            )}
          </div>
          <div class={`grid gap-6 ${gridClass}`}>
            {section.cards.map((card) => (
              <a
                href={card.path}
                class="group rounded-lg border border-border bg-background p-6 transition-all hover:shadow-md hover:border-accent/40"
              >
                <h3 class="text-lg font-bold group-hover:text-primary transition-colors">{card.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{card.description}</p>
                <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-primary">
                  Learn More <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </span>
              </a>
            ))}
          </div>
        </div>
      </section>
    );
  })}

  <!-- FINAL CTA -->
  <section class="py-16 md:py-24">
    <div class="container">
      <div class="mx-auto max-w-2xl rounded-xl border-2 border-accent/30 bg-card p-8 md:p-12 text-center">
        <h2 class="text-2xl font-bold md:text-3xl">Not Sure What You Need?</h2>
        <p class="mt-4 text-muted-foreground leading-relaxed">
          Call us at <a href={business.phoneTel} class="text-primary font-semibold hover:underline">{business.phone}</a> - we'll ask a few questions, figure out what's going on, and point you to the right solution. We answer immediately, any time of day.
        </p>
        <div class="mt-8">
          <a
            href={business.phoneTel}
            class="inline-flex items-center justify-center gap-2 rounded-md bg-accent px-8 py-4 text-base font-bold text-accent-foreground shadow-lg hover:bg-accent/90 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call Now
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
