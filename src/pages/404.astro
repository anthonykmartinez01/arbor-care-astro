---
import BaseLayout from "../components/layout/BaseLayout.astro";
import EstimateModal from "../components/ui/EstimateModal";
import { business } from "../data/business";
---

<BaseLayout
  title="Page Not Found | Arbor Care Tree Solutions"
  description="The page you're looking for may have moved or doesn't exist."
>
  <meta slot="head" name="robots" content="noindex" />

  <div class="py-20 md:py-32">
    <div class="container">
      <div class="mx-auto max-w-2xl text-center">
        <div class="mx-auto mb-6 inline-flex h-20 w-20 items-center justify-center rounded-full bg-muted">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-muted-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        </div>
        <h1 class="text-3xl font-bold md:text-5xl">Page Not Found</h1>
        <p class="mt-4 text-lg text-muted-foreground leading-relaxed">
          The page you're looking for may have moved or doesn't exist. Let us help you find what you need.
        </p>

        <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
          <a
            href="/"
            class="inline-flex items-center gap-2 rounded-md bg-primary px-6 py-3 text-sm font-bold text-primary-foreground hover:bg-primary/90 transition-colors"
          >
            Go to Homepage
          </a>
          <a
            href="/tree-services"
            class="inline-flex items-center gap-2 rounded-md border border-input bg-background px-6 py-3 text-sm font-bold text-foreground hover:bg-muted transition-colors"
          >
            View All Services <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>

        <div class="mt-8 rounded-lg border border-border bg-card p-6">
          <p class="text-sm text-muted-foreground">
            Need immediate help? Call us directly — we answer 24/7.
          </p>
          <a
            href={business.phoneTel}
            class="mt-3 inline-flex items-center gap-2 text-lg font-bold text-primary hover:underline"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            {business.phone}
          </a>
        </div>

        <div class="mt-6">
          <EstimateModal client:load className="inline-flex items-center gap-2 text-sm font-semibold text-primary hover:underline">
            Or request a free estimate →
          </EstimateModal>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
