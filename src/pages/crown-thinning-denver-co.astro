import { business } from "../data/business";
import { scheduleGuard } from "../lib/schedule";

const guard = scheduleGuard(Astro);
if (guard) return guard;

const serviceDescription =
  "Arbor Care Tree Solutions provides crown thinning in Denver that selectively opens dense canopies on trees like silver maples and honeylocusts before spring snowstorms hit, reducing storm damage while preserving the tree's natural shape.";

const faqs = [
  {
    q: "How long does a crown thinning appointment take?",
    a: "Most crown thinning jobs take a few hours to a full day, depending on the tree's size. A mature silver maple or honeylocust with a dense canopy takes longer than a smaller tree. Thomas walks the property first to check crown density and branch attachments before any cutting starts. That first look adds time but saves you from a rushed job. We work through the crown in sections, checking the shape as we go, so bigger or older trees naturally take more time.",
  },
  {
    q: "What should I expect when your crew arrives for crown thinning?",
    a: "You'll see us assess the whole tree before anyone climbs up with a chainsaw. We mark crossing branches and interior deadwood first, then set up climbing gear based on the tree's size and what's nearby, like fences or a garage roof. Cuts happen in small, controlled steps spread evenly around the crown. We stop and check the shape every few cuts instead of stripping one side bare. You'll always know what's coming out and why before we make the cut.",
  },
  {
    q: "What time of year is best for crown thinning in Denver?",
    a: "Late winter or early spring, before Denver's heavy spring snowstorms hit, is the best window. Those storms drop wet, heavy snow while trees still have leaves or thick buds, and a dense canopy catches that snow like a net. Thinning before the storms lets wind and snow pass through the branches instead of piling up. We see the most storm damage on older maples and honeylocusts in neighborhoods like Park Hill, where canopies have gone years without a trim.",
  },
  {
    q: "How much of my tree's canopy will you remove?",
    a: "We only remove select branches spread evenly through the canopy, never a big chunk from one side. The goal is to let light and air move through the tree while keeping its natural shape and size intact. We focus first on crossing branches and interior deadwood, since those cause the most rubbing damage and disease risk. A healthy tree should still look full afterward, just less crowded inside. If a tree needs more removed than that, it may need reduction instead of thinning.",
  },
  {
    q: "How often does a tree need crown thinning?",
    a: "Most healthy trees need thinning every few years, not every season. Trees that grow fast or that haven't been pruned in years, like older silver maples around Denver, often need it more often at first to catch up. Once the canopy is opened up and balanced, future thinning visits are usually lighter. Young trees under five or six years old usually don't need thinning at all, since they're still building their basic branch structure.",
  },
];

const contentToc = [
  { label: "Signs Your Tree's Canopy Is Too Dense", href: "#signs-your-trees-canopy-is-too-dense" },
  { label: "Crown Thinning vs. Crown Reduction: Know the Difference", href: "#crown-thinning-vs-crown-reduction-know-the-difference" },
  { label: "When Crown Thinning Isn't the Right Fix", href: "#when-crown-thinning-isnt-the-right-fix" },
  { label: "What Happens During a Professional Crown Thinning Visit", href: "#what-happens-during-a-professional-crown-thinning-visit" },
  { label: "Timing Crown Thinning Ahead of Denver's Spring Snow Season", href: "#timing-crown-thinning-ahead-of-denvers-spring-snow-season" },
];
const toc = [...contentToc, ...faqs.map((f, i) => ({ label: f.q, href: `#faq-${i}` }))];
