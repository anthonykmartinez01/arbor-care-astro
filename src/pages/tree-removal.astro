---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.tsx";
import Footer from "../components/Footer.astro";
import { EstimateButton } from "../components/EstimateModal.tsx";
---

<Layout title="Tree Removal Denver CO | Safe & Professional | Arbor Care" description="Professional tree removal in Denver, CO. Emergency, hazardous & standard removal. ISA-certified, fully insured. Free estimates. Call (303) 949-6818." canonical="/tree-removal">
  <Header slot="header" pathname="/tree-removal" client:load />

  <main class="min-h-screen">
    <!-- Hero Section -->
    <section
      class="relative h-96 bg-cover bg-center flex items-center justify-center"
      style="background-image: url('/assets/hero-tree-removal.jpg');"
    >
      <div class="absolute inset-0 bg-black/40"></div>
      <div class="relative z-10 text-center text-white px-4">
        <h1 class="text-5xl md:text-6xl font-bold mb-4">Professional Tree Removal</h1>
        <p class="text-xl md:text-2xl">Safe Removal of Any Size Tree</p>
      </div>
    </section>

    <!-- Introduction -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <div class="prose prose-lg max-w-none">
        <p class="text-lg text-gray-700 mb-6">
          Tree removal is a serious task that requires professional expertise and specialized equipment. Whether you have a tree that's dead, diseased, hazardous, or simply in the way, Arbor Care Tree Solutions provides safe, efficient removal services. Our ISA-certified arborists ensure the job is done safely with minimal impact to your property.
        </p>
      </div>
    </section>

    <!-- When You Need Tree Removal -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Signs You Need Tree Removal</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-red-50 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-2">Dead or Dying Tree</h3>
          <p class="text-gray-700">A tree that's no longer living poses a safety hazard and should be removed promptly.</p>
        </div>
        <div class="bg-red-50 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-2">Disease or Pest Damage</h3>
          <p class="text-gray-700">Severe disease or pest infestations may require removal to protect nearby trees.</p>
        </div>
        <div class="bg-red-50 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-2">Storm Damage</h3>
          <p class="text-gray-700">Trees damaged by severe weather may become hazardous and require removal.</p>
        </div>
        <div class="bg-red-50 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-2">Hazardous Location</h3>
          <p class="text-gray-700">Trees growing too close to structures or power lines may need to be removed.</p>
        </div>
      </div>
    </section>

    <!-- Service Options -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Our Removal Services</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white rounded-lg shadow-lg overflow-hidden">
          <div class="bg-red-600 h-24 flex items-center justify-center">
            <span class="text-white text-3xl">🚨</span>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold mb-2"><a href="/emergency-tree-removal-denver-co" class="text-green-600 hover:text-green-700">Emergency Removal</a></h3>
            <p class="text-gray-600 mb-4">24/7 emergency response for storm damage and hazardous situations.</p>
          </div>
        </div>

        <div class="bg-white rounded-lg shadow-lg overflow-hidden">
          <div class="bg-red-600 h-24 flex items-center justify-center">
            <span class="text-white text-3xl">⚠️</span>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold mb-2"><a href="/hazardous-tree-removal-denver-co" class="text-green-600 hover:text-green-700">Hazardous Tree Removal</a></h3>
            <p class="text-gray-600 mb-4">Expert removal of dangerous or hard-to-reach trees.</p>
          </div>
        </div>

        <div class="bg-white rounded-lg shadow-lg overflow-hidden">
          <div class="bg-red-600 h-24 flex items-center justify-center">
            <span class="text-white text-3xl">🌿</span>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold mb-2"><a href="/bush-shrub-removal-denver-co" class="text-green-600 hover:text-green-700">Bush & Shrub Removal</a></h3>
            <p class="text-gray-600 mb-4">Complete removal of unwanted bushes and shrubs.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Process Section -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Our Removal Process</h2>
      <div class="space-y-4">
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 bg-green-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
          <div>
            <h3 class="text-xl font-bold mb-2">Safety Assessment</h3>
            <p class="text-gray-700">We evaluate the tree's condition, size, location, and any hazards.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 bg-green-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
          <div>
            <h3 class="text-xl font-bold mb-2">Professional Removal</h3>
            <p class="text-gray-700">Using proper rigging and cutting techniques, we safely bring down the tree.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 bg-green-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
          <div>
            <h3 class="text-xl font-bold mb-2">Wood Processing</h3>
            <p class="text-gray-700">We chip branches, cut logs, and haul away all debris.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 bg-green-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
          <div>
            <h3 class="text-xl font-bold mb-2">Site Cleanup</h3>
            <p class="text-gray-700">Your property is left clean with no trace of the removal.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Choose Us -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Why Choose Arbor Care?</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="text-center">
          <div class="text-5xl mb-4">🏆</div>
          <h3 class="text-xl font-bold mb-2">ISA Certified</h3>
          <p class="text-gray-700">Our arborists are certified by the International Society of Arboriculture.</p>
        </div>
        <div class="text-center">
          <div class="text-5xl mb-4">🛡️</div>
          <h3 class="text-xl font-bold mb-2">Fully Insured</h3>
          <p class="text-gray-700">Comprehensive liability and workers' compensation insurance.</p>
        </div>
        <div class="text-center">
          <div class="text-5xl mb-4">⚡</div>
          <h3 class="text-xl font-bold mb-2">24/7 Response</h3>
          <p class="text-gray-700">Emergency service available 24/7 for urgent situations.</p>
        </div>
        <div class="text-center">
          <div class="text-5xl mb-4">💰</div>
          <h3 class="text-xl font-bold mb-2">Free Estimates</h3>
          <p class="text-gray-700">No obligation, no trip charge for your free estimate.</p>
        </div>
        <div class="text-center">
          <div class="text-5xl mb-4">🎯</div>
          <h3 class="text-xl font-bold mb-2">Expert Technique</h3>
          <p class="text-gray-700">Specialized equipment and professional rigging for any tree.</p>
        </div>
        <div class="text-center">
          <div class="text-5xl mb-4">🏘️</div>
          <h3 class="text-xl font-bold mb-2">Property Protection</h3>
          <p class="text-gray-700">We protect your home, landscaping, and surrounding trees.</p>
        </div>
      </div>
    </section>

    <!-- Related Services -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Related Services</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href="/stump-grinding-denver-co" class="bg-white rounded-lg shadow-lg p-6 hover:shadow-xl transition text-center">
          <h3 class="text-xl font-bold mb-2 text-green-600">Stump Grinding</h3>
          <p class="text-gray-600">Remove stumps after tree removal</p>
        </a>
        <a href="/tree-trimming" class="bg-white rounded-lg shadow-lg p-6 hover:shadow-xl transition text-center">
          <h3 class="text-xl font-bold mb-2 text-green-600">Tree Trimming</h3>
          <p class="text-gray-600">Preventive tree care and maintenance</p>
        </a>
        <a href="/arborist-service-denver-co" class="bg-white rounded-lg shadow-lg p-6 hover:shadow-xl transition text-center">
          <h3 class="text-xl font-bold mb-2 text-green-600">Arborist Services</h3>
          <p class="text-gray-600">Tree health assessment and expert care</p>
        </a>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="bg-green-600 text-white py-12 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-4xl font-bold mb-4">Need Professional Tree Removal?</h2>
        <p class="text-xl mb-8">Get your free estimate today. Available 24/7 for emergency removal.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="tel:+13039496818" class="bg-white text-green-600 px-8 py-3 rounded-lg font-bold hover:bg-gray-100 transition flex items-center justify-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            Call (303) 949-6818
          </a>
          <EstimateButton client:load className="bg-white text-green-600 px-8 py-3 rounded-lg font-bold hover:bg-gray-100 transition">
            Get Free Estimate
          </EstimateButton>
        </div>
      </div>
    </section>
  </main>

  <Footer slot="footer" />
</Layout>
