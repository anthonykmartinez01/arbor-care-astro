---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.tsx";
import Footer from "../components/Footer.astro";
import { EstimateButton } from "../components/EstimateModal.tsx";
---

<Layout title="Firewood Supply Denver CO | Seasoned Hardwood | Arbor Care" description="Seasoned firewood for sale and delivery in Denver, CO. Split hardwood, cord & face cord. Family owned. Call (303) 949-6818." canonical="/other-services">
  <Header slot="header" pathname="/other-services" client:load />

  <main class="min-h-screen">
    <!-- Hero Section -->
    <section
      class="relative h-96 bg-cover bg-center flex items-center justify-center"
      style="background-image: url('/assets/hero-firewood-supply.jpg');"
    >
      <div class="absolute inset-0 bg-black/40"></div>
      <div class="relative z-10 text-center text-white px-4">
        <h1 class="text-5xl md:text-6xl font-bold mb-4">Premium Firewood Supply</h1>
        <p class="text-xl md:text-2xl">Quality Seasoned Hardwood Delivered</p>
      </div>
    </section>

    <!-- Introduction -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <div class="prose prose-lg max-w-none">
        <p class="text-lg text-gray-700 mb-6">
          Arbor Care Tree Solutions provides premium seasoned firewood for Denver homeowners. Our firewood comes from local tree removal and trimming operations, ensuring a sustainable and cost-effective fuel source for your fireplace or fire pit. All wood is properly seasoned for optimal burning efficiency.
        </p>
      </div>
    </section>

    <!-- Firewood Services -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Our Firewood Services</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white rounded-lg shadow-lg overflow-hidden">
          <div class="bg-red-600 h-24 flex items-center justify-center">
            <span class="text-white text-3xl">🔥</span>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold mb-2"><a href="/seasoned-firewood-denver-co" class="text-green-600 hover:text-green-700">Seasoned Firewood</a></h3>
            <p class="text-gray-600 mb-4">Premium split hardwood, properly seasoned for excellent burning quality.</p>
          </div>
        </div>

        <div class="bg-white rounded-lg shadow-lg overflow-hidden">
          <div class="bg-red-600 h-24 flex items-center justify-center">
            <span class="text-white text-3xl">🚚</span>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold mb-2"><a href="/firewood-delivery-denver-co" class="text-green-600 hover:text-green-700">Firewood Delivery</a></h3>
            <p class="text-gray-600 mb-4">Convenient delivery to your home or business in Denver.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Choose Our Firewood -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Why Choose Arbor Care Firewood?</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-red-50 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-2">Properly Seasoned</h3>
          <p class="text-gray-700">Our wood is seasoned to optimal moisture content for clean, efficient burning.</p>
        </div>
        <div class="bg-red-50 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-2">Quality Hardwood</h3>
          <p class="text-gray-700">Premium hardwoods that burn longer and hotter than softwoods.</p>
        </div>
        <div class="bg-red-50 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-2">Locally Sourced</h3>
          <p class="text-gray-700">Firewood from local tree removal operations, reducing carbon footprint.</p>
        </div>
        <div class="bg-red-50 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-2">Convenient Delivery</h3>
          <p class="text-gray-700">We deliver directly to your home, saving you time and effort.</p>
        </div>
        <div class="bg-red-50 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-2">Competitive Pricing</h3>
          <p class="text-gray-700">Great prices on full cords and face cords.</p>
        </div>
        <div class="bg-red-50 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-2">Consistent Quality</h3>
          <p class="text-gray-700">Every load meets our high quality standards.</p>
        </div>
      </div>
    </section>

    <!-- Firewood Types -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Firewood Options</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white rounded-lg shadow-lg p-6">
          <h3 class="text-2xl font-bold mb-4">Full Cord</h3>
          <p class="text-gray-700 mb-4">A standard full cord measures 4 feet high, 4 feet deep, and 8 feet wide.</p>
          <p class="text-gray-700">Perfect for those with larger fireplaces or who use firewood frequently.</p>
        </div>
        <div class="bg-white rounded-lg shadow-lg p-6">
          <h3 class="text-2xl font-bold mb-4">Face Cord</h3>
          <p class="text-gray-700 mb-4">A face cord is one-third the volume of a full cord, measuring 4 feet high, 8 feet wide, and varies in depth.</p>
          <p class="text-gray-700">Ideal for occasional fireplace use or smaller spaces.</p>
        </div>
      </div>
    </section>

    <!-- Wood Species -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Hardwood Species</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="text-center">
          <div class="text-4xl mb-4">🌲</div>
          <h3 class="text-xl font-bold mb-2">Oak</h3>
          <p class="text-gray-600">Dense, high BTU output, excellent for long burns</p>
        </div>
        <div class="text-center">
          <div class="text-4xl mb-4">🌲</div>
          <h3 class="text-xl font-bold mb-2">Cottonwood</h3>
          <p class="text-gray-600">Local species, good heat output, easy to split</p>
        </div>
        <div class="text-center">
          <div class="text-4xl mb-4">🌲</div>
          <h3 class="text-xl font-bold mb-2">Ash</h3>
          <p class="text-gray-600">Great burning characteristics, minimal sparking</p>
        </div>
      </div>
    </section>

    <!-- Seasoning Info -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">About Seasoned Firewood</h2>
      <div class="bg-blue-50 rounded-lg p-8">
        <h3 class="text-2xl font-bold mb-4">Why Seasoned Wood Matters</h3>
        <p class="text-lg text-gray-700 mb-4">
          Properly seasoned firewood has moisture content below 20%, ensuring:
        </p>
        <ul class="space-y-3 text-gray-700 mb-6">
          <li class="flex items-start">
            <span class="mr-3 text-2xl">✓</span>
            <span><strong>Better burning:</strong> Seasoned wood ignites more easily and burns hotter</span>
          </li>
          <li class="flex items-start">
            <span class="mr-3 text-2xl">✓</span>
            <span><strong>Less smoke:</strong> Proper seasoning reduces smoke and creosote buildup</span>
          </li>
          <li class="flex items-start">
            <span class="mr-3 text-2xl">✓</span>
            <span><strong>Chimney safety:</strong> Reduced creosote means safer fireplace operation</span>
          </li>
          <li class="flex items-start">
            <span class="mr-3 text-2xl">✓</span>
            <span><strong>More heat output:</strong> Dry wood produces more BTUs of heat</span>
          </li>
        </ul>
        <p class="text-lg text-gray-700">
          Green or unseasoned wood wastes money and creates safety hazards. Our firewood is aged and dried to perfection.
        </p>
      </div>
    </section>

    <!-- Delivery Information -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Delivery Information</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white rounded-lg shadow-lg p-6">
          <h3 class="text-2xl font-bold mb-4">Service Area</h3>
          <p class="text-gray-700 mb-4">
            We deliver throughout Denver and surrounding areas. Call for availability in your area.
          </p>
          <p class="text-gray-700">
            <strong>Delivery Area:</strong> Denver metro and surrounding counties
          </p>
        </div>
        <div class="bg-white rounded-lg shadow-lg p-6">
          <h3 class="text-2xl font-bold mb-4">Ordering</h3>
          <p class="text-gray-700 mb-4">
            Contact us to place your firewood order. We can arrange delivery at a time convenient for you.
          </p>
          <p class="text-gray-700">
            <strong>Call (303) 949-6818</strong> to order today
          </p>
        </div>
      </div>
    </section>

    <!-- Related Services -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Related Services</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href="/tree-removal" class="bg-white rounded-lg shadow-lg p-6 hover:shadow-xl transition text-center">
          <h3 class="text-xl font-bold mb-2 text-green-600">Tree Removal</h3>
          <p class="text-gray-600">Source of our quality firewood</p>
        </a>
        <a href="/tree-trimming" class="bg-white rounded-lg shadow-lg p-6 hover:shadow-xl transition text-center">
          <h3 class="text-xl font-bold mb-2 text-green-600">Tree Trimming</h3>
          <p class="text-gray-600">Preventive tree care services</p>
        </a>
        <a href="/stump-grinding-denver-co" class="bg-white rounded-lg shadow-lg p-6 hover:shadow-xl transition text-center">
          <h3 class="text-xl font-bold mb-2 text-green-600">Brush Chipping</h3>
          <p class="text-gray-600">Other wood disposal options</p>
        </a>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="bg-green-600 text-white py-12 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-4xl font-bold mb-4">Order Your Premium Firewood Today</h2>
        <p class="text-xl mb-8">Get seasoned firewood delivered to your Denver home.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="tel:+13039496818" class="bg-white text-green-600 px-8 py-3 rounded-lg font-bold hover:bg-gray-100 transition flex items-center justify-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            Call (303) 949-6818
          </a>
          <EstimateButton client:load className="bg-white text-green-600 px-8 py-3 rounded-lg font-bold hover:bg-gray-100 transition">
            Get Pricing
          </EstimateButton>
        </div>
      </div>
    </section>
  </main>

  <Footer slot="footer" />
</Layout>
