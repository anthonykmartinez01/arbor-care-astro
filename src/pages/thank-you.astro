---
import BaseLayout from "../components/layout/BaseLayout.astro";
import { business } from "../data/business";

const steps = [
  { step: "1", text: "We review your request and put together an estimate." },
  { step: "2", text: "One of our team members will call or text you to go over the details." },
  { step: "3", text: "We schedule a time that works for you and get the job done right." },
];
---

<BaseLayout
  title="Thank You | Arbor Care Tree Solutions"
  description="Thank you for contacting Arbor Care Tree Solutions. We'll be in touch soon."
>
  <meta slot="head" name="robots" content="noindex" />

  <section class="relative min-h-[60vh] flex items-center justify-center bg-muted">
    <!-- Decorative background -->
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute -top-24 -right-24 h-96 w-96 rounded-full bg-accent/10 blur-3xl"></div>
      <div class="absolute -bottom-24 -left-24 h-96 w-96 rounded-full bg-primary/10 blur-3xl"></div>
    </div>

    <div class="container relative z-10 py-20">
      <div class="mx-auto max-w-2xl text-center">
        <!-- Success icon -->
        <div class="mx-auto mb-8 flex h-24 w-24 items-center justify-center rounded-full bg-accent/20">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-14 w-14 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
        </div>

        <h1 class="text-3xl font-bold md:text-5xl text-foreground">
          Thank You!
        </h1>
        <p class="mt-4 text-lg text-muted-foreground md:text-xl">
          We got your message and will reach out soon - usually within a few hours.
        </p>

        <!-- What happens next -->
        <div class="mt-10 rounded-xl border border-border bg-card p-8 text-left">
          <h2 class="mb-6 text-xl font-bold text-foreground">What happens next?</h2>
          <ol class="space-y-5">
            {steps.map((item) => (
              <li class="flex items-start gap-4">
                <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-accent text-sm font-bold text-accent-foreground">
                  {item.step}
                </span>
                <span class="text-muted-foreground pt-1">{item.text}</span>
              </li>
            ))}
          </ol>
        </div>

        <!-- CTAs -->
        <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
          <a href={business.phoneTel} class="inline-flex items-center justify-center gap-2 rounded-md bg-accent px-8 py-6 text-lg font-bold text-accent-foreground shadow-lg hover:bg-accent/90 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call Us Now
          </a>
          <a href="/" class="inline-flex items-center justify-center gap-2 rounded-md border border-input bg-background px-8 py-6 text-lg font-bold text-foreground hover:bg-muted transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            Back to Home
          </a>
        </div>

        <p class="mt-6 text-sm text-muted-foreground">
          Need help right away? Call us at <a href={business.phoneTel} class="font-semibold text-primary hover:underline">{business.phone}</a> - we answer immediately, 24/7.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
