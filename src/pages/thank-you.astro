---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.tsx";
import Footer from "../components/Footer.astro";
---

<Layout title="Thank You | Arbor Care Tree Solutions" description="Thank you for contacting Arbor Care Tree Solutions." canonical="/thank-you">
  <Header slot="header" pathname="/thank-you" client:load />

  <main class="min-h-screen">
    <!-- Hero Section -->
    <section class="bg-gradient-to-r from-green-600 to-green-800 text-white py-16 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-5xl md:text-6xl font-bold mb-4">Thank You!</h1>
        <p class="text-xl md:text-2xl">We've Received Your Message</p>
      </div>
    </section>

    <!-- Success Message -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <div class="bg-green-50 rounded-lg p-8 text-center">
        <div class="text-6xl mb-6">✓</div>
        <h2 class="text-4xl font-bold mb-4 text-gray-800">Thank You for Contacting Us!</h2>
        <p class="text-lg text-gray-700 mb-6">
          We've received your estimate request or message. Our team will review it and get back to you as soon as possible.
        </p>
        <div class="bg-white rounded-lg p-6 mb-6">
          <h3 class="text-2xl font-bold mb-4">What Happens Next?</h3>
          <ul class="space-y-3 text-gray-700 text-left max-w-2xl mx-auto">
            <li class="flex items-start">
              <span class="mr-3 text-2xl text-green-600">1.</span>
              <span><strong>We'll Review Your Request</strong> - Our team will carefully review the details you provided.</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3 text-2xl text-green-600">2.</span>
              <span><strong>We'll Contact You</strong> - We'll call or email to confirm your estimate appointment or answer your questions.</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3 text-2xl text-green-600">3.</span>
              <span><strong>Schedule Your Estimate</strong> - We'll work with you to find a convenient time for your free estimate.</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3 text-2xl text-green-600">4.</span>
              <span><strong>Professional Assessment</strong> - Our arborist will visit your property and provide a detailed estimate.</span>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Timeline -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Response Timeline</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white rounded-lg shadow-lg p-6">
          <h3 class="text-2xl font-bold mb-3 text-green-600">Business Hours</h3>
          <p class="text-gray-700 mb-3">
            We aim to contact you within <strong>24 hours</strong> during normal business hours (Monday-Friday).
          </p>
          <p class="text-gray-600">For urgent matters, we're available 24/7 for emergency requests.</p>
        </div>
        <div class="bg-white rounded-lg shadow-lg p-6">
          <h3 class="text-2xl font-bold mb-3 text-green-600">Scheduling</h3>
          <p class="text-gray-700 mb-3">
            Most estimate appointments can be scheduled within <strong>1-2 business days</strong>.
          </p>
          <p class="text-gray-600">We'll work with you to find a time that's convenient for your schedule.</p>
        </div>
      </div>
    </section>

    <!-- Contact Information -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Have a Question?</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white rounded-lg shadow-lg p-6 text-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-600 mx-auto mb-4"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          <h3 class="text-xl font-bold mb-2">Call Us</h3>
          <a href="tel:+13039496818" class="text-green-600 hover:text-green-700 font-semibold text-lg">
            (303) 949-6818
          </a>
          <p class="text-gray-600 text-sm mt-2">Available 24/7</p>
        </div>

        <div class="bg-white rounded-lg shadow-lg p-6 text-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-600 mx-auto mb-4"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
          <h3 class="text-xl font-bold mb-2">Email Us</h3>
          <a href="mailto:ArborCareTreeSolutions@gmail.com" class="text-green-600 hover:text-green-700 font-semibold break-all">
            ArborCareTreeSolutions@gmail.com
          </a>
          <p class="text-gray-600 text-sm mt-2">We'll respond quickly</p>
        </div>

        <div class="bg-white rounded-lg shadow-lg p-6 text-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-600 mx-auto mb-4"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
          <h3 class="text-xl font-bold mb-2">Visit Us</h3>
          <p class="text-gray-700 font-semibold">
            1130 S Santa Fe Dr<br />
            Denver, CO 80223
          </p>
        </div>
      </div>
    </section>

    <!-- Explore More -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">In the Meantime...</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href="/tree-services" class="bg-white rounded-lg shadow-lg p-6 hover:shadow-xl transition text-center">
          <div class="text-4xl mb-4">🌳</div>
          <h3 class="text-xl font-bold mb-2 text-green-600">Our Services</h3>
          <p class="text-gray-700">Learn more about our complete tree care services.</p>
        </a>

        <a href="/our-work" class="bg-white rounded-lg shadow-lg p-6 hover:shadow-xl transition text-center">
          <div class="text-4xl mb-4">📸</div>
          <h3 class="text-xl font-bold mb-2 text-green-600">Our Work</h3>
          <p class="text-gray-700">See photos of completed projects and results.</p>
        </a>

        <a href="/about-arbor-care-index" class="bg-white rounded-lg shadow-lg p-6 hover:shadow-xl transition text-center">
          <div class="text-4xl mb-4">👥</div>
          <h3 class="text-xl font-bold mb-2 text-green-600">About Us</h3>
          <p class="text-gray-700">Meet our team and learn our story.</p>
        </a>
      </div>
    </section>

    <!-- Return to Home -->
    <section class="bg-gray-50 py-12 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl font-bold mb-6">Return to Homepage</h2>
        <a href="/" class="bg-green-600 text-white px-8 py-3 rounded-lg font-bold hover:bg-green-700 transition inline-block">
          Back to Home
        </a>
      </div>
    </section>
  </main>

  <Footer slot="footer" />
</Layout>
