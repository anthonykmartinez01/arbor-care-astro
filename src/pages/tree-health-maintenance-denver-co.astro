---
import BaseLayout from "../components/layout/BaseLayout.astro";
import ServiceSchema from "../components/schema/ServiceSchema.astro";
import FAQSchema from "../components/schema/FAQSchema.astro";
import PageContents from "../components/sections/PageContents.astro";
import CtaBanner from "../components/sections/CtaBanner.astro";
import ContentSection from "../components/sections/ContentSection.astro";
import FaqAccordion from "../components/sections/FaqAccordion.astro";
import RelatedArboristServices from "../components/sections/RelatedArboristServices.astro";
import { business } from "../data/business";
import { scheduleGuard } from "../lib/schedule";

const guard = scheduleGuard(Astro);
if (guard) return guard;

const serviceDescription =
  "Arbor Care Tree Solutions provides on-site tree health assessments across Denver, checking canopy condition, trunk integrity, and root-zone soil issues tied to the area's dense clay soil and wide temperature swings.";

const faqs = [
  {
    q: "How quickly can you get out to look at my tree in Denver?",
    a: "We schedule most tree health visits within a few days of your call. If you're seeing fast decline, like a canopy that thinned out over just a few weeks, tell us that when you book. We move those visits up because quick spread usually means something is actively feeding on the tree or the roots are choking. Denver's weather swings hard between hot and cold, so timing matters more here than in milder climates.",
  },
  {
    q: "What happens during a tree health assessment?",
    a: "We walk your whole property, not just the one tree you're worried about. That means checking the canopy from a few angles, looking at the trunk for cracks or oozing, and inspecting the soil line for buried root flare or fungus. We also look at nearby trees, since shared root systems can spread stress between them. The whole visit usually takes less than an hour, and you'll get a clear answer about what's normal and what needs attention.",
  },
  {
    q: "Why does my tree look stressed even though I water it?",
    a: "Denver's clay soil is often the real problem, not lack of water. Clay holds moisture so tight near the surface that roots can't pull it down when they need it, so water runs off instead of soaking in. We see this constantly on visits, an owner who waters faithfully but still has a tree with thin, early-dropping leaves. Fixing it usually means adjusting mulch and helping water reach deeper roots, not adding more water on top.",
  },
  {
    q: "How do I know if my tree just has normal fall color or is sick?",
    a: "A tree changing color in September and dropping leaves on schedule is usually fine. A problem looks different: leaves dropping in June, dieback on one side while the rest stays green, or decline that's clearly getting worse week to week. That uneven pattern is the biggest red flag. If your tree leafed out fully this spring and the trunk looks solid, it's probably just having a normal seasonal year.",
  },
  {
    q: "Should I be worried about emerald ash borer on my ash tree?",
    a: "If your ash tree has a thinning canopy or bark that's splitting and peeling, it's worth having someone check for borer activity. Ash trees around Denver carry extra risk right now, and borer damage can look a lot like ordinary drought stress at first glance. The difference matters, because borer damage spreads fast and needs a different response than a tree that just needs better watering. An in-person look is the only way to tell them apart.",
  },
];

const contentToc = [
  { label: "Reading the Signs of a Stressed Tree in Denver", href: "#reading-the-signs-of-a-stressed-tree-in-denver" },
  { label: "Drought Stress and Clay Soil: The Hidden Cause Behind Many Symptoms", href: "#drought-stress-and-clay-soil-the-hidden-cause-behind-many-sy" },
  { label: "When Your Tree Doesn't Need Treatment Yet", href: "#when-your-tree-doesnt-need-treatment-yet" },
  { label: "What Happens During a Professional Tree Health Assessment", href: "#what-happens-during-a-professional-tree-health-assessment" },
  { label: "Pest and Disease Treatment as Part of Ongoing Health Care", href: "#pest-and-disease-treatment-as-part-of-ongoing-health-care" },
];
const toc = [...contentToc, ...faqs.map((f, i) => ({ label: f.q, href: `#faq-${i}` }))];
---

<BaseLayout
  title="Tree Health Maintenance Denver CO | Arbor Care Tree Solutions"
  description="Tree health maintenance in Denver, CO. Spot drought stress, clay-soil problems, pests, and ash borer early. ISA-certified arborists. Call (303) 949-6818."
  preloadImage="/assets/tree-health-maintenance-spruce-inspection-denver.webp"
  preloadImageMobile="/assets/tree-health-maintenance-spruce-inspection-denver-mobile.webp"
>
  <ServiceSchema slot="head" name="Tree Health Maintenance" description={serviceDescription} url="/tree-health-maintenance-denver-co/" />
  <FAQSchema slot="head" faqs={faqs} />

  <!-- HERO -->
  <section class="relative flex min-h-[500px] items-center overflow-hidden md:min-h-[60vh]">
    <picture>
      <source media="(max-width: 767px)" srcset="/assets/tree-health-maintenance-spruce-inspection-denver-mobile.webp" width="800" height="800" />
      <img
        src="/assets/tree-health-maintenance-spruce-inspection-denver.webp"
        alt="Arbor Care Tree Solutions arborist inspecting a spruce for tree health in Denver, CO"
        class="absolute inset-0 h-full w-full object-cover"
        width="1024"
        height="1024"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
    </picture>
    <div class="absolute inset-0 bg-black/60"></div>
    <div class="container relative z-10 py-20 pb-28 text-center md:py-28">
      <div class="mx-auto max-w-3xl">
        <h1 class="text-3xl font-bold leading-tight text-white md:text-5xl">
          Tree Health Maintenance in Denver
          <span class="mt-2 block text-xl text-accent md:text-2xl">Spot Trouble Before It Spreads</span>
        </h1>
        <p class="mx-auto mt-4 text-lg text-white/80">
          Licensed, fully insured, and serving all of Denver and the surrounding areas.
        </p>
        <div class="mt-8">
          <a
            href={business.phoneTel}
            class="inline-flex items-center justify-center gap-2 rounded-md bg-accent px-8 py-4 text-base font-bold text-accent-foreground shadow-lg transition-colors hover:bg-accent/90"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call Now {business.phone}
          </a>
        </div>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 bg-primary/95 backdrop-blur-sm">
      <div class="container flex flex-wrap items-center justify-center gap-x-8 gap-y-2 py-3 text-sm text-primary-foreground">
        <span class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>
          <span class="font-medium">Licensed & Fully Insured</span>
        </span>
        <span class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
          <span class="font-medium">ISA-Certified Arborists</span>
        </span>
        <span class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          <span class="font-medium">Serves All of Denver</span>
        </span>
        <span class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span class="font-medium">Available 24/7</span>
        </span>
      </div>
    </div>
  </section>

  <!-- TABLE OF CONTENTS -->
  <PageContents items={toc} />

  <CtaBanner heading="Need Tree Health Maintenance?" />

  <!-- CONTENT SECTIONS -->
  <ContentSection
    id="reading-the-signs-of-a-stressed-tree-in-denver"
    heading="Reading the Signs of a Stressed Tree in Denver"
    image={{ src: "/assets/tree-health-maintenance-leaf-stress-signs-denver.webp", alt: "Close-up of dry curling aspen leaf showing tree stress signs in Denver", title: "tree-health-maintenance-leaf-stress-signs-denver", align: "left" }}
  >
    <p>A stressed tree doesn't scream for help. It whispers, and most homeowners miss it until the whisper turns into a falling branch. We walk properties every week where the owner had no idea anything was wrong until we pointed it out.</p>
    <p>Denver's clay-heavy soil and dry summers put a lot of strain on trees that weren't built for it. Front Range trees deal with swings from ninety-degree heat to a sudden freeze in the same week, and that kind of stress shows up slow. Ash trees around Denver carry an extra risk right now, thinning canopies and bark splitting can point to emerald ash borer damage, not just drought.</p>
    <p>Here's what we tell clients to watch for:</p>
    <ul>
      <li>Leaves that are smaller than normal, or that turn color and drop early in the season</li>
      <li>Bark that's cracking, peeling, or missing in patches</li>
      <li>Dead branches near the top of the canopy while the bottom still looks fine</li>
      <li>Fungus or mushrooms growing at the base of the trunk</li>
      <li>Sap or sawdust piles near the trunk, a sign something's feeding inside</li>
    </ul>
    <p>Not sure if what you're seeing is normal seasonal shedding or a real problem? That's a fair question, and it's one we get all the time. A tree dropping leaves in October is fine. A tree dropping leaves in June is not.</p>
    <p>Nine times out of ten, the tree that finally falls gave warning signs for a full year before it happened. Thin canopy this spring, a few dead limbs by summer, then a storm in August finishes the job. Catching it in spring changes everything about what we can do to save it.</p>
  </ContentSection>

  <ContentSection
    id="drought-stress-and-clay-soil-the-hidden-cause-behind-many-sy"
    heading="Drought Stress and Clay Soil: The Hidden Cause Behind Many Symptoms"
    alt={true}
    image={{ src: "/assets/tree-health-maintenance-clay-soil-drought-denver.webp", alt: "Cracked clay soil and root probe near Denver tree showing drought stress", title: "tree-health-maintenance-clay-soil-drought-denver", align: "right" }}
  >
    <p>Here's something most homeowners don't know until we tell them. Denver sits on heavy clay soil, and that clay is working against your tree every single day. Clay holds water so tight that roots can't pull it out when they need it most. Then it dries and cracks, and water just runs off the surface instead of soaking in. Your tree ends up thirsty even after a good rain.</p>
    <p>We see this constantly on tree health maintenance visits: a tree that looks stressed, thin leaves, early fall color in August, and the owner swears they've been watering. They have. The water just isn't reaching the roots that need it. Denver's semi-arid climate doesn't help either. Low humidity, intense sun, and wind pull moisture out of leaves faster than clay soil can resupply the roots.</p>
    <p>Front Range trees, especially ones planted in newer developments where topsoil got stripped during construction, are fighting an uphill battle from day one.</p>
    <p>So what do we look for? Soil compaction near the trunk. Mulch that's piled wrong or missing entirely. Watering patterns that soak the surface but never reach deeper roots. And root flare that's buried under years of added soil or mulch, which suffocates the tree slowly.</p>
    <p>Fixing drought stress isn't about dumping more water on the problem. It's about getting water to penetrate that clay, adjusting mulch depth, and sometimes aerating compacted soil around the root zone. That's the kind of diagnosis an ISA Certified Arborist is trained to make, not guess at. Thomas Fraser has spent 30 years reading these exact patterns in Denver yards, and nine times out of ten, the clay soil is doing more damage than the tree owner ever suspected.</p>
  </ContentSection>

  <ContentSection
    id="when-your-tree-doesnt-need-treatment-yet"
    heading="When Your Tree Doesn't Need Treatment Yet"
    image={{ src: "/assets/tree-health-maintenance-homeowner-review-denver.webp", alt: "Denver homeowner reviewing tree photos before deciding on tree health treatment", title: "tree-health-maintenance-homeowner-review-denver", align: "left" }}
  >
    <p>Not every yellow leaf means trouble. That's the truth, and we'd rather tell you now than send someone out to bill you for nothing.</p>
    <p>Deciduous trees around Denver drop color early some falls, especially after a dry August. A honeylocust or ash going gold in September isn't sick, it's reading the calendar. Same goes for a few dead twigs way up in the crown of an older cottonwood. That's normal shedding, not decline. Every mature tree carries some deadwood. It's how they grow.</p>
    <p>Here's a simple gut check before you call anyone out. Look at the whole tree, not one branch. Is the trunk solid, no cracks or oozing? Is most of the canopy still full and green in season? Did the tree leaf out fine this spring? If you answered yes to those, you're probably looking at a tree that just needs to be left alone, maybe with a light prune down the road.</p>
    <p>We get calls from folks near City Park worried about oak leaves curling in July heat. Nine times out of ten it's just heat stress from a hot dry stretch, not disease. The tree bounces back once temperatures drop and it gets a good soak.</p>
    <p>So when do you need us? When the decline is spread across the whole canopy, when it's new this year and getting worse fast, or when you're seeing dieback on the south side while the rest looks fine, that uneven pattern usually points to a real problem worth a look. If your tree's just going through its normal seasonal moods, save your money and enjoy the yard.</p>
  </ContentSection>

  <CtaBanner
    heading="Have questions? We're happy to help."
    note="Call now for a free estimate. Arbor Care Tree Solutions is ready to help."
  />

  <ContentSection
    id="what-happens-during-a-professional-tree-health-assessment"
    heading="What Happens During a Professional Tree Health Assessment"
    alt={true}
    image={{ src: "/assets/tree-health-maintenance-soil-moisture-assessment-denver.webp", alt: "Arborist measuring soil moisture during professional tree health assessment in Denver", title: "tree-health-maintenance-soil-moisture-assessment-denver", align: "right" }}
  >
    <p>Here's what happens when we walk your property for a tree health assessment. We're not just looking at the tree, we're looking at the whole picture, the soil around it, the grade of your yard, what's been planted nearby.</p>
    <p>Thomas Fraser has done this for 30 years, and the process follows a pattern that works:</p>
    <ol>
      <li>Walk the full canopy from multiple angles, checking for dead limbs, thinning foliage, or lopsided growth</li>
      <li>Check the trunk for cracks, cankers, oozing sap, or bark that's peeling in odd patches</li>
      <li>Inspect the root flare and soil line for fungus, girdling roots, or soil piled too high against the trunk</li>
      <li>Test branch flexibility and check for deadwood that could drop in a windstorm</li>
      <li>Look at nearby trees and structures for signs of shared stress, root competition, or construction damage</li>
    </ol>
    <p>Denver's clay-heavy soil compacts fast, especially in yards that got regraded during a remodel. That compaction chokes roots slowly, over years, and by the time the canopy shows it the tree's already stressed hard.</p>
    <p>We also check for pest and disease patterns common around here. Ash trees get flagged for borer activity, evergreens get checked for needle cast, and anything near a sprinkler line gets a look at root rot risk. It's not guesswork.</p>
    <p>An ISA Certified Arborist reads these signs against real tree biology, not a checklist someone printed off the internet. That's the difference between a health assessment and someone just eyeballing your yard from the truck.</p>
    <p>Most assessments take under an hour. You'll get a straight answer on what's going on, what it means for the tree, and what your options are, no pressure, no upsell games.</p>
  </ContentSection>

  <ContentSection
    id="pest-and-disease-treatment-as-part-of-ongoing-health-care"
    heading="Pest and Disease Treatment as Part of Ongoing Health Care"
    image={{ src: "/assets/tree-health-maintenance-pest-treatment-ash-tree-denver.webp", alt: "Arborist applying pest treatment spray to ash tree bark in Denver", title: "tree-health-maintenance-pest-treatment-ash-tree-denver", align: "left" }}
  >
    <p>Tree health maintenance isn't just pruning and mulch. Half the job is catching problems before they turn into a removal bill. We're out on Denver properties every week looking at leaf color, bark texture, canopy thinning, the stuff most homeowners don't notice until it's bad.</p>
    <p>Denver's ash trees are a real concern right now. Emerald ash borer has been confirmed in the metro area, and it kills trees fast once it's established. Thin canopy, D-shaped exit holes in the bark, woodpecker damage, these are the signs we check for on every ash tree we inspect. Catch it early and treatment can slow the damage. Wait too long, and removal becomes the only option.</p>
    <p>It's not just ash trees. Colorado's dry stretches and heavy clay soil put a lot of stress on root systems along the Front Range. Stressed trees are an open invitation for bark beetles and fungal disease. We see <a href="https://tcimag.tcia.org/training/the-most-common-phc-issues-and-solutions-around-the-u-s/" target="_blank" rel="noopener">Ips beetle activity spike</a> on pines during hot, dry summers, and drought-stressed spruce trees pick up needle cast without much warning.</p>
    <p>Our team's ISA-Certified Arborist background matters here. Diagnosis isn't guesswork, it's pattern recognition built over years of looking at the same problems.</p>
  </ContentSection>

  <!-- FAQ -->
  <FaqAccordion faqs={faqs} subheading="Common questions about tree health maintenance in Denver" />

  <!-- RELATED (arborist cluster: siblings + hub) -->
  <RelatedArboristServices currentSlug="/tree-health-maintenance-denver-co/" />

  <!-- BOTTOM CTA -->
  <section class="py-16 md:py-24">
    <div class="container">
      <div class="mx-auto max-w-2xl rounded-xl border-2 border-accent/30 bg-card p-8 text-center md:p-12">
        <h2 class="text-2xl font-bold md:text-3xl">Ready to Get Started?</h2>
        <p class="mt-4 leading-relaxed text-muted-foreground">
          Call <a href={business.phoneTel} class="font-semibold text-primary hover:underline">{business.phone}</a> now for a free estimate. We answer immediately, any time of day.
        </p>
        <div class="mt-8">
          <a
            href={business.phoneTel}
            class="inline-flex items-center justify-center gap-2 rounded-md bg-accent px-8 py-4 text-base font-bold text-accent-foreground shadow-lg transition-colors hover:bg-accent/90"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call {business.phone}
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
