---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.tsx";
import Footer from "../components/Footer.astro";
import { EstimateButton } from "../components/EstimateModal.tsx";
---

<Layout title="Arborist Services Denver CO | ISA-Certified | Arbor Care" description="ISA-certified arborist services in Denver, CO. Health assessments, treatment plans, expert planting. Free estimates. Call (303) 949-6818." canonical="/arborist-service-denver-co">
  <Header slot="header" pathname="/arborist-service-denver-co" client:load />

  <main class="min-h-screen">
    <!-- Hero Section -->
    <section
      class="relative h-96 bg-cover bg-center flex items-center justify-center"
      style="background-image: url('/assets/hero-arborist-services.jpg');"
    >
      <div class="absolute inset-0 bg-black/40"></div>
      <div class="relative z-10 text-center text-white px-4">
        <h1 class="text-5xl md:text-6xl font-bold mb-4">Expert Arborist Services</h1>
        <p class="text-xl md:text-2xl">Professional Tree Health & Care</p>
      </div>
    </section>

    <!-- Introduction -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <div class="prose prose-lg max-w-none">
        <p class="text-lg text-gray-700 mb-6">
          Our ISA-certified arborists provide comprehensive tree health services to keep your trees thriving for generations. From health assessments and disease treatment to expert planting and maintenance recommendations, we have the knowledge and experience to care for your valuable landscape assets.
        </p>
      </div>
    </section>

    <!-- Service Options -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Our Arborist Services</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white rounded-lg shadow-lg overflow-hidden">
          <div class="bg-blue-600 h-24 flex items-center justify-center">
            <span class="text-white text-3xl">🔍</span>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold mb-2"><a href="/tree-health-assessment-denver-co" class="text-green-600 hover:text-green-700">Tree Health Assessment</a></h3>
            <p class="text-gray-600 mb-4">Comprehensive evaluation of tree health, structure, and pest issues.</p>
          </div>
        </div>

        <div class="bg-white rounded-lg shadow-lg overflow-hidden">
          <div class="bg-blue-600 h-24 flex items-center justify-center">
            <span class="text-white text-3xl">💊</span>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold mb-2"><a href="/tree-treatment-denver-co" class="text-green-600 hover:text-green-700">Tree Treatment</a></h3>
            <p class="text-gray-600 mb-4">Treatment plans for disease, insects, and nutrient deficiencies.</p>
          </div>
        </div>

        <div class="bg-white rounded-lg shadow-lg overflow-hidden">
          <div class="bg-blue-600 h-24 flex items-center justify-center">
            <span class="text-white text-3xl">🌱</span>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold mb-2"><a href="/tree-planting-denver-co" class="text-green-600 hover:text-green-700">Tree Planting</a></h3>
            <p class="text-gray-600 mb-4">Expert selection and planting of trees for Denver's climate.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Arborist Services -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Why Professional Arborist Services?</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-blue-50 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-2">Preserve Your Investment</h3>
          <p class="text-gray-700">Trees are valuable assets. Professional care ensures they remain healthy and beautiful for decades.</p>
        </div>
        <div class="bg-blue-50 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-2">Prevent Disease Spread</h3>
          <p class="text-gray-700">Early detection and treatment prevent diseases from spreading to other trees.</p>
        </div>
        <div class="bg-blue-50 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-2">Enhance Safety</h3>
          <p class="text-gray-700">Professional assessments identify hazards before they become dangerous.</p>
        </div>
        <div class="bg-blue-50 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-2">Increase Property Value</h3>
          <p class="text-gray-700">Well-maintained trees significantly increase curb appeal and property value.</p>
        </div>
      </div>
    </section>

    <!-- Certification -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">ISA Certified Arborists</h2>
      <div class="bg-green-50 rounded-lg p-8">
        <p class="text-lg text-gray-700 mb-4">
          Our arborists are certified by the International Society of Arboriculture (ISA), the premier organization for arboriculture professionals. ISA certification requires extensive knowledge, experience, and continuing education.
        </p>
        <p class="text-lg text-gray-700 mb-4">
          This certification ensures you're receiving advice and services from qualified professionals who stay current with the latest tree care research and best practices.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div class="text-center">
            <div class="text-4xl mb-2">📚</div>
            <h3 class="font-bold">Extensive Knowledge</h3>
            <p class="text-sm text-gray-600">Tree biology, ecology, and care</p>
          </div>
          <div class="text-center">
            <div class="text-4xl mb-2">✅</div>
            <h3 class="font-bold">Regular Testing</h3>
            <p class="text-sm text-gray-600">Certified through rigorous exams</p>
          </div>
          <div class="text-center">
            <div class="text-4xl mb-2">🔄</div>
            <h3 class="font-bold">Continuing Education</h3>
            <p class="text-sm text-gray-600">Keep skills current with industry advances</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Denver Climate Section -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Denver Climate Expertise</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
        <div>
          <h3 class="text-2xl font-bold mb-4">Understanding Denver's Trees</h3>
          <p class="text-lg text-gray-700 mb-4">
            Denver's high altitude, low humidity, and intense summer sun create unique challenges for trees. Our local arborists understand these conditions and know which species thrive in Denver.
          </p>
          <ul class="space-y-3 text-gray-700">
            <li className="flex items-start">
              <span className="mr-3">🌲</span>
              <span>Experience with native and adapted species</span>
            </li>
            <li className="flex items-start">
              <span className="mr-3">☀️</span>
              <span>Understanding of altitude and sun exposure</span>
            </li>
            <li className="flex items-start">
              <span className="mr-3">💧</span>
              <span>Knowledge of water management in dry climate</span>
            </li>
            <li className="flex items-start">
              <span className="mr-3">❄️</span>
              <span>Expertise in winter protection strategies</span>
            </li>
          </ul>
        </div>
        <div>
          <img src="/assets/hero-climber.jpg" alt="Arborist assessing tree health" class="rounded-lg shadow-lg" />
        </div>
      </div>
    </section>

    <!-- What to Expect -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Our Process</h2>
      <div class="space-y-4">
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 bg-green-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
          <div>
            <h3 class="text-xl font-bold mb-2">Comprehensive Assessment</h3>
            <p class="text-gray-700">We evaluate tree health, structure, pest and disease issues, and environmental factors.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 bg-green-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
          <div>
            <h3 class="text-xl font-bold mb-2">Detailed Report</h3>
            <p class="text-gray-700">You receive a thorough report with findings and recommendations.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 bg-green-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
          <div>
            <h3 class="text-xl font-bold mb-2">Treatment Plan</h3>
            <p class="text-gray-700">We develop a customized care plan addressing identified issues.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 bg-green-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
          <div>
            <h3 class="text-xl font-bold mb-2">Ongoing Care</h3>
            <p class="text-gray-700">We implement treatments and provide follow-up care as needed.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Choose Us -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Why Choose Arbor Care?</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="text-center">
          <div class="text-5xl mb-4">🏆</div>
          <h3 class="text-xl font-bold mb-2">ISA Certified</h3>
          <p class="text-gray-700">Certified arborists with continuous education</p>
        </div>
        <div class="text-center">
          <div class="text-5xl mb-4">📊</div>
          <h3 class="text-xl font-bold mb-2">Data-Driven</h3>
          <p class="text-gray-700">Evidence-based recommendations and solutions</p>
        </div>
        <div class="text-center">
          <div class="text-5xl mb-4">🎯</div>
          <h3 class="text-xl font-bold mb-2">Customized Plans</h3>
          <p class="text-gray-700">Treatment plans tailored to your trees' needs</p>
        </div>
        <div class="text-center">
          <div class="text-5xl mb-4">💰</div>
          <h3 class="text-xl font-bold mb-2">Free Assessments</h3>
          <p class="text-gray-700">No obligation consultation and evaluation</p>
        </div>
        <div class="text-center">
          <div class="text-5xl mb-4">🏘️</div>
          <h3 class="text-xl font-bold mb-2">Local Expertise</h3>
          <p class="text-gray-700">Deep knowledge of Denver's trees and climate</p>
        </div>
        <div class="text-center">
          <div class="text-5xl mb-4">📋</div>
          <h3 class="text-xl font-bold mb-2">Licensed & Insured</h3>
          <p class="text-gray-700">Fully protected for your security</p>
        </div>
      </div>
    </section>

    <!-- Related Services -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Related Services</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href="/tree-trimming" class="bg-white rounded-lg shadow-lg p-6 hover:shadow-xl transition text-center">
          <h3 class="text-xl font-bold mb-2 text-green-600">Tree Trimming</h3>
          <p class="text-gray-600">Professional pruning and maintenance</p>
        </a>
        <a href="/tree-removal" class="bg-white rounded-lg shadow-lg p-6 hover:shadow-xl transition text-center">
          <h3 class="text-xl font-bold mb-2 text-green-600">Tree Removal</h3>
          <p class="text-gray-600">Safe removal of hazardous trees</p>
        </a>
        <a href="/stump-grinding-denver-co" class="bg-white rounded-lg shadow-lg p-6 hover:shadow-xl transition text-center">
          <h3 class="text-xl font-bold mb-2 text-green-600">Stump Grinding</h3>
          <p class="text-gray-600">Complete stump removal</p>
        </a>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="bg-green-600 text-white py-12 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-4xl font-bold mb-4">Get Professional Arborist Services</h2>
        <p class="text-xl mb-8">Schedule your free tree health assessment today.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="tel:+13039496818" class="bg-white text-green-600 px-8 py-3 rounded-lg font-bold hover:bg-gray-100 transition flex items-center justify-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            Call (303) 949-6818
          </a>
          <EstimateButton client:load className="bg-white text-green-600 px-8 py-3 rounded-lg font-bold hover:bg-gray-100 transition">
            Get Free Assessment
          </EstimateButton>
        </div>
      </div>
    </section>
  </main>

  <Footer slot="footer" />
</Layout>
