---
import BaseLayout from "../components/layout/BaseLayout.astro";
import ServiceSchema from "../components/schema/ServiceSchema.astro";
import EstimateModalNative from "../components/ui/EstimateModalNative.astro";
import { business } from "../data/business";
---

<BaseLayout
  title="Arborist Service Denver CO | ISA-Certified Tree Care Experts"
  description="ISA-certified arborist services in Denver, CO. Tree health assessments, disease treatment & professional tree care. Free estimates. Call (303) 949-6818."
  canonical="/arborist-service-denver-co"
>
  <ServiceSchema
    slot="head"
    name="Arborist Services Denver CO"
    description="ISA-certified arborist services in Denver, Colorado including tree health assessments, tree treatment, and tree planting."
    url="/arborist-service-denver-co"
  />

  <!-- HERO -->
  <section class="relative min-h-[500px] md:min-h-[60vh] flex items-center overflow-hidden">
    <picture>
      <source media="(max-width: 767px)" srcset="/assets/hero-arborist-services-mobile.webp" width="800" height="450" />
      <img
        src="/assets/hero-arborist-services.webp"
        alt="ISA certified arborist inspecting a tree in Denver Colorado"
        class="absolute inset-0 h-full w-full object-cover"
        width="1920"
        height="1080"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
    </picture>
    <div class="absolute inset-0 bg-black/60"></div>
    <div class="container relative z-10 py-20 pb-28 md:py-28 text-center">
      <div class="mx-auto max-w-3xl">
        <h1 class="text-3xl font-bold text-white md:text-5xl lg:text-6xl leading-tight">
          Arborist Service in Denver, CO
          <span class="block text-accent mt-2">Protecting Your Trees for Life</span>
        </h1>
        <p class="mx-auto mt-6 text-lg text-white/90 md:text-xl max-w-2xl">
          Denver's trees face real threats - drought, disease, bark beetles, and brutal
          Front Range storms. Our ISA-certified arborists assess, treat, and care for your
          trees so problems are caught before they become emergencies. Available 24/7. Free
          estimates. Call{" "}
          <a href={business.phoneTel} class="underline font-semibold text-accent hover:text-accent/80">{business.phone}</a>.
        </p>
        <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
          <a href={business.phoneTel} class="inline-flex items-center justify-center gap-2 rounded-md bg-accent px-8 py-4 text-base font-bold text-accent-foreground shadow-lg hover:bg-accent/90 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            Call {business.phone}
          </a>
          <EstimateModalNative className="inline-flex items-center justify-center gap-2 rounded-md bg-white/15 backdrop-blur border border-white/30 px-8 py-4 text-base font-bold text-white hover:bg-white/25 transition-colors">
            Get Free Estimate
          </EstimateModalNative>
        </div>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 bg-primary/95 backdrop-blur-sm">
      <div class="container flex flex-wrap items-center justify-center gap-x-8 gap-y-2 py-3 text-sm text-primary-foreground">
        <span class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
          <span class="font-medium">100+ Five-Star Reviews</span>
        </span>
        <span class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"></circle><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"></path></svg>
          <span class="font-medium">ISA-Certified Arborists</span>
        </span>
        <span class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"></path></svg>
          <span class="font-medium">No Trip Charge</span>
        </span>
        <span class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
          <span class="font-medium">Family Owned</span>
        </span>
      </div>
    </div>
  </section>

  <!-- OPENING -->
  <section class="py-16 md:py-24">
    <div class="container">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-lg leading-relaxed text-muted-foreground">
          You've noticed something off about your trees - maybe a dead limb you can't ignore,
          unusual bark discoloration, or branches that came down after the last wind storm.
          You're not sure if it's serious or something that will work itself out. The problem
          is, most tree issues that look minor on the surface are already much worse underneath.
          By the time a tree looks visibly sick or damaged, you're often past the point where
          easy fixes apply.
        </p>
        <p class="mt-6 text-lg leading-relaxed text-foreground font-medium">
          You're in the right place. Arbor Care Tree Solutions serves Denver homeowners with
          ISA-certified arborist services — which means every assessment, treatment, and tree
          care decision is made by someone with the training and credentials to actually know
          what they're looking at. We don't guess. We diagnose.
        </p>
      </div>
    </div>
  </section>

  <!-- WHAT PROBLEMS -->
  <section class="bg-muted py-16 md:py-24">
    <div class="container">
      <h2 class="text-center text-2xl font-bold md:text-4xl">
        What Arborist Problems Are You Dealing With?
      </h2>
      <p class="mx-auto mt-6 max-w-3xl text-center text-muted-foreground leading-relaxed">
        Most Denver homeowners contact us after noticing something they can't explain:
        yellowing leaves in summer, bark that's peeling or weeping, a trunk that seems to
        be leaning more than it used to, or large sections of canopy that didn't leaf out
        this spring. These are warning signs - not cosmetic issues.
      </p>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <!-- EAB -->
        <div class="rounded-lg border border-border bg-background p-6 text-center">
          <div class="mx-auto mb-4 inline-flex h-12 w-12 items-center justify-center rounded-full bg-destructive/10">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-destructive" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m8 2 1.88 1.88"></path><path d="M14.12 3.88 16 2"></path><path d="M9 7.13v-1a3.003 3.003 0 1 1 6 0v1"></path><path d="M12 20c-3.3 0-6-2.7-6-6v-3a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v3c0 3.3-2.7 6-6 6"></path><path d="M12 20v-9"></path><path d="M6.53 9C4.6 8.8 3 7.1 3 5"></path><path d="M6 13H2"></path><path d="M3 21c0-2.1 1.7-3.9 3.8-4"></path><path d="M20.97 5c0 2.1-1.6 3.8-3.5 4"></path><path d="M22 13h-4"></path><path d="M17.2 17c2.1.1 3.8 1.9 3.8 4"></path></svg>
          </div>
          <p class="text-sm leading-relaxed text-muted-foreground">Emerald Ash Borer silently killing ash trees across the Denver metro</p>
        </div>
        <!-- Bark beetle -->
        <div class="rounded-lg border border-border bg-background p-6 text-center">
          <div class="mx-auto mb-4 inline-flex h-12 w-12 items-center justify-center rounded-full bg-destructive/10">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-destructive" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"></path><path d="M12 9v4"></path><path d="M12 17h.01"></path></svg>
          </div>
          <p class="text-sm leading-relaxed text-muted-foreground">Bark beetle infestations stressing pine and spruce before visible decline</p>
        </div>
        <!-- Drought -->
        <div class="rounded-lg border border-border bg-background p-6 text-center">
          <div class="mx-auto mb-4 inline-flex h-12 w-12 items-center justify-center rounded-full bg-destructive/10">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-destructive" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3c-.29 1.45-1.14 2.84-2.29 3.76S3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05z"></path><path d="M12.56 6.6A10.97 10.97 0 0 0 14 3.02c.5 2.5 2 4.9 4 6.5s3 3.5 3 5.5a6.98 6.98 0 0 1-11.91 4.97"></path></svg>
          </div>
          <p class="text-sm leading-relaxed text-muted-foreground">Drought weakening root systems over multiple seasons</p>
        </div>
        <!-- Heavy snow -->
        <div class="rounded-lg border border-border bg-background p-6 text-center">
          <div class="mx-auto mb-4 inline-flex h-12 w-12 items-center justify-center rounded-full bg-destructive/10">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-destructive" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="2" x2="22" y1="12" y2="12"></line><line x1="12" x2="12" y1="2" y2="22"></line><path d="m20 16-4-4 4-4"></path><path d="m4 8 4 4-4 4"></path><path d="m16 4-4 4-4-4"></path><path d="m8 20 4-4 4 4"></path></svg>
          </div>
          <p class="text-sm leading-relaxed text-muted-foreground">Heavy wet spring snow snapping branches and splitting trunks</p>
        </div>
      </div>
      <p class="mx-auto mt-10 max-w-3xl text-center text-muted-foreground leading-relaxed">
        DIY treatments rarely work because tree diseases and infestations require the right
        diagnosis before any treatment can help. Applying the wrong product wastes time and
        money, and delays proper care while the problem gets worse. A certified arborist
        identifies exactly what's happening and prescribes a solution that actually addresses it.
      </p>
    </div>
  </section>

  <!-- OUR SERVICES -->
  <section class="py-16 md:py-24">
    <div class="container">
      <h2 class="text-center text-2xl font-bold md:text-4xl">
        Our Arborist Services in Denver
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-center text-muted-foreground">
        Our arborist work covers three core areas that address the full lifecycle of tree health.
      </p>
      <div class="mt-12 space-y-8">
        <!-- Tree Health Assessment -->
        <div class="flex flex-col gap-6 rounded-xl border border-border bg-card p-8 md:flex-row md:items-start">
          <div class="flex-shrink-0">
            <div class="inline-flex h-16 w-16 items-center justify-center rounded-full bg-accent/15">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
            </div>
          </div>
          <div class="flex-1">
            <a href="/tree-health-assessment-denver-co" class="text-xl font-bold text-primary hover:underline">Tree Health Assessment</a>
            <p class="mt-3 leading-relaxed text-muted-foreground">We begin with a thorough tree health assessment, where one of our ISA-certified arborists examines the tree's structure, root zone, bark condition, and canopy health. This gives us a clear picture of what the tree is dealing with - whether that's pest damage, disease, environmental stress, or structural issues that pose a risk to your property. The assessment is the foundation for everything else we recommend.</p>
            <a href="/tree-health-assessment-denver-co" class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-primary hover:underline">
              Learn more about Tree Health Assessment <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg>
            </a>
          </div>
        </div>
        <!-- Tree Treatment -->
        <div class="flex flex-col gap-6 rounded-xl border border-border bg-card p-8 md:flex-row md:items-start md:flex-row-reverse">
          <div class="flex-shrink-0">
            <div class="inline-flex h-16 w-16 items-center justify-center rounded-full bg-accent/15">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.8 2.3A.3.3 0 1 0 5 2H4a2 2 0 0 0-2 2v5a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3"></path><path d="M8 15v1a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6v-4"></path><circle cx="20" cy="10" r="2"></circle></svg>
            </div>
          </div>
          <div class="flex-1">
            <a href="/tree-treatment-denver-co" class="text-xl font-bold text-primary hover:underline">Tree Treatment</a>
            <p class="mt-3 leading-relaxed text-muted-foreground">If a tree is treatable, we move into tree treatment. This includes targeted pesticide and fungicide applications for known infestations and infections, deep root fertilization to help stressed trees rebuild their strength, and soil improvement for trees showing signs of drought or compaction damage. We use treatment methods appropriate for the species, the specific problem, and the surrounding environment.</p>
            <a href="/tree-treatment-denver-co" class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-primary hover:underline">
              Learn more about Tree Treatment <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg>
            </a>
          </div>
        </div>
        <!-- Tree Planting -->
        <div class="flex flex-col gap-6 rounded-xl border border-border bg-card p-8 md:flex-row md:items-start">
          <div class="flex-shrink-0">
            <div class="inline-flex h-16 w-16 items-center justify-center rounded-full bg-accent/15">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 20h10"></path><path d="M10 20c5.5-2.5.8-6.4 3-10"></path><path d="M9.5 9.4c1.1.8 1.8 2.2 2.3 3.7-2 .4-3.5.4-4.8-.3-1.2-.6-2.3-1.9-3-4.2 2.8-.5 4.4 0 5.5.8z"></path><path d="M14.1 6a7 7 0 0 0-1.1 4c1.9-.1 3.3-.6 4.3-1.4 1-1 1.6-2.3 1.7-4.6-2.7.1-4 1-4.9 2z"></path></svg>
            </div>
          </div>
          <div class="flex-1">
            <a href="/tree-planting-denver-co" class="text-xl font-bold text-primary hover:underline">Tree Planting</a>
            <p class="mt-3 leading-relaxed text-muted-foreground">We also handle tree planting for homeowners looking to replace a lost tree or add new ones to their landscape. Proper planting — the right species for the site, correct depth, adequate soil prep — is what determines whether a new tree thrives or struggles for years. We guide you through species selection based on your soil type, sun exposure, and the conditions specific to your neighborhood in Denver.</p>
            <a href="/tree-planting-denver-co" class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-primary hover:underline">
              Learn more about Tree Planting <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FOR DENVER HOMES -->
  <section class="bg-muted py-16 md:py-24">
    <div class="container">
      <div class="mx-auto max-w-4xl">
        <div class="grid gap-8 md:grid-cols-5">
          <div class="md:col-span-3">
            <h2 class="text-2xl font-bold md:text-4xl">
              Arborist Services for Denver Homes
            </h2>
            <p class="mt-6 leading-relaxed text-muted-foreground">
              Tree care in Denver isn't the same as tree care in a wetter or milder climate. The
              combination of high altitude, intense UV exposure, clay-heavy soils in many
              neighborhoods, and extreme temperature swings creates a specific set of stressors
              that trees here have to constantly manage. Our arborists work in Denver's neighborhoods
              every day and they know what's common in each area.
            </p>
            <p class="mt-4 leading-relaxed text-muted-foreground">
              Ash trees in established Denver neighborhoods are at high risk for Emerald Ash Borer.
              Pine and spruce trees in areas bordering open space are more susceptible to bark beetle
              pressure. Older cottonwoods along drainage corridors have specific structural
              vulnerabilities after years of growth. Local expertise isn't just a selling point —
              it's the difference between a treatment plan that works and one that misses the actual
              problem.
            </p>
            <p class="mt-4 leading-relaxed text-muted-foreground">
              We're also familiar with Denver's municipal requirements around tree removal near
              parkways and city-owned trees, and we can help you navigate those rules when they
              apply to your situation.
            </p>
          </div>
          <div class="md:col-span-2">
            <div class="rounded-lg border border-border bg-background p-6">
              <div class="mb-4 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                <h3 class="font-bold">Service Areas</h3>
              </div>
              <ul class="space-y-2">
                {business.serviceAreas.map((area) => (
                  <li class="flex items-center gap-2 text-sm text-muted-foreground">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><path d="m9 11 3 3L22 4"></path></svg>
                    {area}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY CHOOSE US -->
  <section class="py-16 md:py-24">
    <div class="container">
      <h2 class="text-center text-2xl font-bold md:text-4xl">
        Why Choose Us for Arborist Services
      </h2>
      <p class="mx-auto mt-6 max-w-3xl text-center text-muted-foreground leading-relaxed">
        Arbor Care Tree Solutions is a family-owned company serving Denver with ISA-certified
        arborists on staff. We're members of the Tree Care Industry Association (TCIA), fully
        licensed and insured in Colorado, and have earned 100+ five-star Google reviews from
        Denver homeowners.
      </p>
      <div class="mx-auto mt-10 grid max-w-3xl gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <div class="flex items-center gap-3 rounded-lg border border-border bg-card p-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"></circle><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"></path></svg>
          <span class="text-sm font-medium">ISA-certified arborists on staff</span>
        </div>
        <div class="flex items-center gap-3 rounded-lg border border-border bg-card p-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
          <span class="text-sm font-medium">Family-owned, TCIA member</span>
        </div>
        <div class="flex items-center gap-3 rounded-lg border border-border bg-card p-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path><path d="m9 12 2 2 4-4"></path></svg>
          <span class="text-sm font-medium">Fully licensed &amp; insured in Colorado</span>
        </div>
        <div class="flex items-center gap-3 rounded-lg border border-border bg-card p-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
          <span class="text-sm font-medium">100+ five-star Google reviews</span>
        </div>
        <div class="flex items-center gap-3 rounded-lg border border-border bg-card p-4">
