---
import BaseLayout from "../components/layout/BaseLayout.astro";
import ServiceSchema from "../components/schema/ServiceSchema.astro";
import FAQSchema from "../components/schema/FAQSchema.astro";
import PageContents from "../components/sections/PageContents.astro";
import CtaBanner from "../components/sections/CtaBanner.astro";
import ContentSection from "../components/sections/ContentSection.astro";
import FaqAccordion from "../components/sections/FaqAccordion.astro";
import { business } from "../data/business";

const serviceDescription =
  "Arbor Care Tree Solutions provides full-service arborist care across Denver, including tree trimming, crown reduction, disease diagnosis, and storm damage assessment for residential properties from Washington Park to surrounding neighborhoods.";

const faqs = [
  {
    q: "Do you serve all of Denver, including neighborhoods like Washington Park?",
    a: "Yes, we work across all of Denver, from Washington Park to the surrounding neighborhoods. We climb trees on residential lots, near driveways, and along property lines throughout the city. Response times can vary based on storm activity, since severe weather often brings a rush of calls. If a tree looks unstable, call us right away so we can get you on the schedule fast.",
  },
  {
    q: "What should I do if a tree is growing into power lines?",
    a: "Call an arborist instead of trimming it yourself. Trees near power lines are common in older Denver neighborhoods with narrow sidewalk strips and mature canopies. Cutting branches near live wires is dangerous and can also damage the tree if it's done wrong. We handle this kind of trimming safely and can tell you if the growth pattern will keep causing problems.",
  },
  {
    q: "How do I know if my tree needs trimming or a crown reduction?",
    a: "Trimming fixes small problems like low branches or minor overgrowth. Crown reduction is for trees that have outgrown their space, with branches hanging over a roof or leaning heavy after storms. If your tree feels top-heavy or you're worried about weight over your house, ask for a crown reduction assessment instead of a standard trim.",
  },
  {
    q: "Should I get my tree checked after a storm even if it looks fine?",
    a: "Yes, hidden damage doesn't always show from the ground. Denver storms bring hail, wind, and heavy snow that can crack a trunk or loosen roots without visible signs. We check the base, root flare, and upper canopy for cracks or splits you can't see. Waiting weeks to have it looked at raises the risk of a limb or whole tree coming down.",
  },
  {
    q: "How do I know if my ash or elm tree is sick?",
    a: "Watch for thinning leaves, bark splitting in strips, or small D-shaped holes in the trunk. Ash and elm trees make up a large share of Denver's older neighborhoods, and both face serious disease pressure right now. Early treatment works better than waiting, so get it checked as soon as you notice any of these signs on your tree.",
  },
  {
    q: "When should I call an arborist instead of handling a tree issue myself?",
    a: "Call an arborist any time a tree is near a structure, power line, or shows signs of disease or damage. Denver's clay soil and storm patterns make tree problems harder to judge than they look. A quick assessment tells you exactly what's wrong and what treatment or trimming actually fixes it, instead of guessing and risking bigger damage later.",
  },
];

const contentToc = [
  { label: "Tree Trimming and Pruning for Denver Yards", href: "#tree-trimming-and-pruning-for-denver-yards" },
  { label: "Tree Risk Assessment After Storms", href: "#tree-risk-assessment-after-storms" },
  { label: "Tree Disease Treatment for Ash and Elm Trees", href: "#tree-disease-treatment-for-ash-and-elm-trees" },
  { label: "Tree Health Maintenance for Long-Term Canopy Care", href: "#tree-health-maintenance-for-longterm-canopy-care" },
  { label: "Crown Reduction for Oversized Canopies", href: "#crown-reduction-for-oversized-canopies" },
  { label: "Crown Thinning for Dense Canopies", href: "#crown-thinning-for-dense-canopies" },
  { label: "Deadwooding for Safety and Storm Prep", href: "#deadwooding-for-safety-and-storm-prep" },
];
const toc = [...contentToc, ...faqs.map((f, i) => ({ label: f.q, href: `#faq-${i}` }))];
---

<BaseLayout
  title="Arborist Service Denver CO | ISA-Certified Tree Care Experts"
  description="ISA-certified arborist services in Denver, CO. Tree health assessments, disease treatment & professional tree care. Free estimates. Call (303) 949-6818."
  preloadImage="/assets/arborist-service-tree-trimming-bucket-truck-denver.webp"
  preloadImageMobile="/assets/arborist-service-tree-trimming-bucket-truck-denver-mobile.webp"
>
  <ServiceSchema slot="head" name="Arborist Service" description={serviceDescription} url="/arborist-service-denver-co/" />
  <FAQSchema slot="head" faqs={faqs} />

  <!-- HERO -->
  <section class="relative flex min-h-[500px] items-center overflow-hidden md:min-h-[60vh]">
    <picture>
      <source media="(max-width: 767px)" srcset="/assets/arborist-service-tree-trimming-bucket-truck-denver-mobile.webp" width="800" height="800" />
      <img
        src="/assets/arborist-service-tree-trimming-bucket-truck-denver.webp"
        alt="Arborist trimming a mature tree from a bucket truck in Denver, CO"
        class="absolute inset-0 h-full w-full object-cover"
        width="1024"
        height="1024"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
    </picture>
    <div class="absolute inset-0 bg-black/60"></div>
    <div class="container relative z-10 py-20 pb-28 text-center md:py-28">
      <div class="mx-auto max-w-3xl">
        <h1 class="text-3xl font-bold leading-tight text-white md:text-5xl">
          Arborist Service in Denver
          <span class="mt-2 block text-xl text-accent md:text-2xl">Trimming, Crown Care, Disease Treatment & Storm Assessments</span>
        </h1>
        <p class="mx-auto mt-4 text-lg text-white/80">
          Licensed, fully insured, and serving all of Denver and the surrounding areas.
        </p>
        <div class="mt-8">
          <a
            href={business.phoneTel}
            class="inline-flex items-center justify-center gap-2 rounded-md bg-accent px-8 py-4 text-base font-bold text-accent-foreground shadow-lg transition-colors hover:bg-accent/90"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call Now {business.phone}
          </a>
        </div>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 bg-primary/95 backdrop-blur-sm">
      <div class="container flex flex-wrap items-center justify-center gap-x-8 gap-y-2 py-3 text-sm text-primary-foreground">
        <span class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>
          <span class="font-medium">Licensed & Fully Insured</span>
        </span>
        <span class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
          <span class="font-medium">ISA-Certified Arborists</span>
        </span>
        <span class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          <span class="font-medium">Serves All of Denver</span>
        </span>
        <span class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span class="font-medium">Available 24/7</span>
        </span>
      </div>
    </div>
  </section>

  <!-- TABLE OF CONTENTS -->
  <PageContents items={toc} />

  <CtaBanner heading="Need Arborist Service?" />

  <!-- CONTENT SECTIONS -->
  <ContentSection
    id="tree-trimming-and-pruning-for-denver-yards"
    heading="Tree Trimming and Pruning for Denver Yards"
    image={{ src: "/assets/arborist-service-pruning-tools-equipment-denver.webp", alt: "Close-up of arborist pruning tools and rope in Denver", title: "arborist-service-pruning-tools-equipment-denver", align: "left" }}
  >
    <p>This is probably our busiest service, and there's a reason for it. Denver's dry summers and heavy spring snow put real stress on branches. Untrimmed trees drop limbs during those wet April storms, sometimes right onto a fence or a roof. Regular pruning keeps that from happening.</p>
    <p>We trim for a few reasons. Sometimes a tree's grown into power lines near the sidewalk. Sometimes low branches are blocking a driveway in Washington Park or scraping a second-story window. And sometimes it's just about shape, an overgrown tree that's shading out the whole yard.</p>
    <p>Good pruning cuts do more than clean things up. They:</p>
    <ul>
      <li>Remove weak or crossing branches before they fail</li>
      <li>Open up the canopy so air and light get through</li>
      <li>Reduce weight on limbs that snow tends to collect on</li>
      <li>Encourage stronger growth the following season</li>
    </ul>
    <p>Timing matters here. Late winter works for most species in Denver, before buds break. But some trees need summer trims instead, it depends on the species and what you're trying to fix.</p>
    <p>We've been climbing Denver trees for over 20 years, and every yard's a little different. The dedicated <a href="/tree-trimming/">trimming page</a> walks through our process and what a typical visit looks like.</p>
  </ContentSection>

  <ContentSection
    id="tree-risk-assessment-after-storms"
    heading="Tree Risk Assessment After Storms"
    alt={true}
    image={{ src: "/assets/arborist-service-healthy-tree-result-denver.webp", alt: "Healthy pruned tree with homeowner and arborist in Denver yard", title: "arborist-service-healthy-tree-result-denver", align: "right" }}
  >
    <p>Denver storms hit fast. One minute it's calm, the next you've got hail, straight-line winds, or heavy wet snow bending branches you thought were solid. After weather like that, we get calls from folks who aren't sure if their tree is fine or one bad gust from coming down.</p>
    <p>A <a href="/tree-health-assessment-denver-co/">risk assessment</a> is us walking your property and checking the tree from the roots up. We look at the trunk for cracks, check root flare for heaving or soil lift, and study the canopy for hanging limbs or splits you can't see from the ground. And we've caught plenty of hidden problems this way, decay pockets and weak unions that looked fine until we got up close.</p>
    <p>Watch for these signs after any big storm:</p>
    <ul>
      <li>Leaning that wasn't there before</li>
      <li>Cracked or split bark near the base</li>
      <li>Broken limbs stuck in the upper canopy</li>
      <li>Soil lifting on one side of the trunk</li>
    </ul>
    <p>This isn't guesswork. We've assessed storm damage across Denver for over twenty years, and which trees recover and which ones become a liability. If you're unsure who to call, Denver's city forester keeps a list of <a href="https://www.denvergov.org/Government/Agencies-Departments-Offices/Agencies-Departments-Offices-Directory/Parks-Recreation/Trees-Natural-Resources/Office-of-the-City-Forester/Tree-Service-Contractor-Resources" target="_blank" rel="noopener">licensed arborist contractor resources</a> for property owners. If a tree fails on your property, it can take out a fence, a roof, or worse. So don't wait weeks to have it checked.</p>
  </ContentSection>

  <ContentSection id="tree-disease-treatment-for-ash-and-elm-trees" heading="Tree Disease Treatment for Ash and Elm Trees">
    <p>Ash and elm trees make up a huge chunk of Denver's urban canopy. That's a problem, because both species face serious disease pressure right now. Dutch elm disease has been working through older neighborhoods for years. Emerald ash borer showed up in Colorado back in 2013 and hasn't slowed down since.</p>
    <p>We get more calls about this than anything else in late spring and early summer, when leaf-out reveals which trees made it through winter healthy and which didn't.</p>
    <p>Signs your ash or elm needs attention:</p>
    <ul>
      <li>Thinning canopy or dead branches near the top</li>
      <li>Bark splitting in vertical strips</li>
      <li>D-shaped exit holes in the trunk</li>
      <li>Wilting leaves that curl before fall</li>
      <li>Sucker growth at the base</li>
    </ul>
    <p><a href="/tree-treatment-denver-co/">Treatment</a> options depend on how far the disease has progressed. Early cases often respond to trunk injections or soil treatments. Advanced cases might need pruning to remove infected limbs before the problem spreads to healthy wood.</p>
    <p>Homes near Washington Park have some of the oldest elms in Denver, and we treat several every season. Waiting rarely helps here. But a quick assessment can tell you exactly where your tree stands and what treatment makes sense for it.</p>
  </ContentSection>

  <CtaBanner heading="Not sure what your arborist service project needs? Ask us." note="Call now for a free estimate. Arbor Care Tree Solutions is ready to help." />

  <ContentSection id="tree-health-maintenance-for-longterm-canopy-care" heading="Tree Health Maintenance for Long-Term Canopy Care" alt={true}>
    <p>Denver's soil is tough on trees. Clay-heavy, alkaline, and stingy with water unless you're irrigating year-round. So trees here need more than a once-and-done trim. They need ongoing care that matches what our climate does to root systems and canopy over time.</p>
    <p>Tree health maintenance is the long game. It's not one visit, it's a plan built around your tree's species, age, and site conditions.</p>
    <ul>
      <li>Soil testing and amendment for our alkaline clay soils</li>
      <li>Deep root fertilization timed to Denver's growing season</li>
      <li>Mulching to hold moisture during dry summer stretches</li>
      <li>Pest and stress monitoring before problems take hold</li>
      <li>Watering schedules built around our low humidity</li>
    </ul>
    <p>I've walked properties in Washington Park where a single maple was struggling for three straight seasons, and it wasn't disease. It was compacted soil choking the roots. A maintenance plan caught it before we lost the tree.</p>
  </ContentSection>

  <ContentSection
    id="crown-reduction-for-oversized-canopies"
    heading="Crown Reduction for Oversized Canopies"
    image={{ src: "/assets/arborist-service-denver-neighborhood-street-trees.webp", alt: "Denver street with mature trees and arborist service truck", title: "arborist-service-denver-neighborhood-street-trees", align: "left" }}
  >
    <p>Some trees just outgrow their spot. A silver maple in a Washington Park backyard can push branches over the roofline in ten years flat. That's where crown reduction comes in. We cut back the outer branches to shrink the whole canopy, without hacking off the top or leaving stubs.</p>
    <p>This isn't the same as topping a tree. Topping is a bad shortcut that weakens the structure and invites disease. Crown reduction works with the tree's natural shape, cutting at proper lateral points so it heals clean and keeps growing right.</p>
    <p>You'll want this service if:</p>
    <ul>
      <li>Branches hang over your roof, deck, or power lines</li>
      <li>The tree feels top-heavy or lopsided after storms</li>
      <li>You're trying to keep a big tree from shading out your whole yard</li>
      <li>A recent Denver windstorm left you nervous about what's overhead</li>
    </ul>
    <p>I've walked plenty of yards in Denver where a crown reduction saved a tree that homeowners assumed had to come down. Cutting size down doesn't mean cutting corners, either. We size every cut to the branch's diameter and the tree's species, because a reduction done wrong stresses the tree more than doing nothing at all.</p>
    <p>The dedicated <a href="/crown-reduction-denver-co/">crown reduction page</a> walks through how we decide how much to take off and why timing matters more than most people think.</p>
  </ContentSection>

  <ContentSection
    id="crown-thinning-for-dense-canopies"
    heading="Crown Thinning for Dense Canopies"
    alt={true}
    image={{ src: "/assets/tree-risk-assessment-storm-damage-elm-denver.webp", alt: "Arborist inspects storm-damaged elm tree trunk in Denver", title: "tree-risk-assessment-storm-damage-elm-denver", align: "right" }}
  >
    <p>Crown thinning removes select branches throughout the canopy to let air and light pass through. It's different from crown reduction. We're not making the tree smaller, we're making it less crowded inside.</p>
    <p>Denver's older neighborhoods like Park Hill and Washington Park have a lot of mature silver maples and elms with thick, layered growth. Dense canopies catch wind like a sail. And that's a real problem during our spring windstorms, when gusts off the Front Range hit 50 or 60 miles an hour. A thinned crown lets wind move through instead of pushing against it.</p>
    <p>Here's what usually pushes homeowners to call us for this:</p>
    <ul>
      <li>Branches rubbing or crossing inside the canopy</li>
      <li>Grass or garden beds struggling under heavy shade</li>
      <li>A tree that feels "top heavy" or leans after storms</li>
      <li>Interior deadwood building up from lack of sunlight</li>
    </ul>
    <p>I've climbed enough Denver trees to know a poorly thinned crown does more harm than good. Over-thinning stresses the tree and invites sunscald on thin bark species. We remove branches in a pattern that keeps the tree balanced, not stripped. This work takes an eye trained on how each species responds, not just a saw and a ladder.</p>
  </ContentSection>

  <CtaBanner heading="Ready when you are — get in touch today." note="Call now for a free estimate. Arbor Care Tree Solutions is ready to help." />

  <ContentSection
    id="deadwooding-for-safety-and-storm-prep"
    heading="Deadwooding for Safety and Storm Prep"
    image={{ src: "/assets/tree-disease-treatment-ash-elm-bark-sample-denver.webp", alt: "Arborist examines diseased ash tree bark in Denver yard", title: "tree-disease-treatment-ash-elm-bark-sample-denver", align: "left" }}
  >
    <p>Dead branches don't creak and warn you before they drop. They just let go. And in Denver, that's a real problem, our freeze-thaw cycles crack limbs from the inside out long before you ever see it on the outside.</p>
    <p><a href="/deadwooding-denver-co/">Deadwooding</a> means we go through your tree and cut out the dead, dying, or diseased wood. Nothing else gets touched. This is different from crown thinning, we're not shaping the tree here, we're removing hazards.</p>
    <p>Here's when we get called for this most:</p>
    <ul>
      <li>After a spring hailstorm rolls through Washington Park and snaps small branches loose</li>
      <li>Before a big wind event, since dead limbs are the first thing to fail</li>
      <li>When you notice bark falling off in patches or branches with no leaves in summer</li>
      <li>Ahead of selling a home, since inspectors flag dead wood over walkways</li>
    </ul>
    <p>I've climbed trees in Cherry Creek where the dead wood was invisible from the ground but obvious once you're up in the canopy. That's the value of having someone trained look closely.</p>
    <p>Leaving dead branches up is asking for a call to your insurance company. Get it cleared out before the next storm, not after.</p>
  </ContentSection>

  <!-- FAQ -->
  <FaqAccordion faqs={faqs} subheading="Common questions about arborist service in Denver" />

  <!-- BOTTOM CTA -->
  <section class="py-16 md:py-24">
    <div class="container">
      <div class="mx-auto max-w-2xl rounded-xl border-2 border-accent/30 bg-card p-8 text-center md:p-12">
        <h2 class="text-2xl font-bold md:text-3xl">Ready to Get Started?</h2>
        <p class="mt-4 leading-relaxed text-muted-foreground">
          Call <a href={business.phoneTel} class="font-semibold text-primary hover:underline">{business.phone}</a> now for a free estimate. We answer immediately, any time of day.
        </p>
        <div class="mt-8">
          <a
            href={business.phoneTel}
            class="inline-flex items-center justify-center gap-2 rounded-md bg-accent px-8 py-4 text-base font-bold text-accent-foreground shadow-lg transition-colors hover:bg-accent/90"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call {business.phone}
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
