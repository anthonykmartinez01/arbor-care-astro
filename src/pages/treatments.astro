---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.tsx";
import Footer from "../components/Footer.astro";
import { EstimateButton } from "../components/EstimateModal.tsx";
---

<Layout title="Spring Tree Cleanup Denver CO | Arbor Care" description="Spring tree cleanup and treatment services in Denver. Storm damage assessment, pruning, and preventive treatments." canonical="/treatments">
  <Header slot="header" pathname="/treatments" client:load />

  <main class="min-h-screen">
    <!-- Hero Section -->
    <section class="bg-gradient-to-r from-green-600 to-blue-600 text-white py-16 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-5xl md:text-6xl font-bold mb-4">Spring Tree Cleanup & Care</h1>
        <p class="text-xl md:text-2xl">Prepare Your Trees for the Growing Season</p>
      </div>
    </section>

    <!-- Introduction -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <div class="prose prose-lg max-w-none">
        <p class="text-lg text-gray-700 mb-6">
          Spring is the perfect time to assess your trees and prepare them for healthy growth. At Arbor Care Tree Solutions, we offer comprehensive spring cleanup and treatment services to get your Denver trees ready for the season ahead. From storm damage assessment to preventive treatments, we ensure your trees are healthy and safe.
        </p>
      </div>
    </section>

    <!-- Spring Services -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Spring Tree Services</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white rounded-lg shadow-lg p-6">
          <h3 class="text-2xl font-bold mb-3">Storm Damage Assessment</h3>
          <p class="text-gray-700 mb-4">
            Inspect trees for winter and spring storm damage. We identify broken branches, leaning trees, and hazardous conditions.
          </p>
          <ul class="space-y-2 text-gray-700 text-sm">
            <li>✓ Damage inspection</li>
            <li>✓ Safety evaluation</li>
            <li>✓ Repair recommendations</li>
          </ul>
        </div>

        <div class="bg-white rounded-lg shadow-lg p-6">
          <h3 class="text-2xl font-bold mb-3">Dead Branch Removal</h3>
          <p class="text-gray-700 mb-4">
            Remove winter-killed and dead branches that have accumulated. Improves tree appearance and health.
          </p>
          <ul class="space-y-2 text-gray-700 text-sm">
            <li>✓ Deadwood removal</li>
            <li>✓ Hazard pruning</li>
            <li>✓ Cleanup included</li>
          </ul>
        </div>

        <div class="bg-white rounded-lg shadow-lg p-6">
          <h3 class="text-2xl font-bold mb-3">Spring Pruning</h3>
          <p class="text-gray-700 mb-4">
            Professional pruning to encourage healthy spring growth and establish good tree structure.
          </p>
          <ul class="space-y-2 text-gray-700 text-sm">
            <li>✓ Growth pruning</li>
            <li>✓ Canopy thinning</li>
            <li>✓ Shape improvement</li>
          </ul>
        </div>

        <div class="bg-white rounded-lg shadow-lg p-6">
          <h3 class="text-2xl font-bold mb-3">Preventive Treatments</h3>
          <p class="text-gray-700 mb-4">
            Preventive treatments for common spring pests and diseases that threaten Denver trees.
          </p>
          <ul class="space-y-2 text-gray-700 text-sm">
            <li>✓ Pest prevention</li>
            <li>✓ Disease treatment</li>
            <li>✓ Health monitoring</li>
          </ul>
        </div>

        <div class="bg-white rounded-lg shadow-lg p-6">
          <h3 class="text-2xl font-bold mb-3">Mulching & Ground Care</h3>
          <p class="text-gray-700 mb-4">
            Fresh mulch improves soil moisture retention and protects tree health as growth season begins.
          </p>
          <ul class="space-y-2 text-gray-700 text-sm">
            <li>✓ Mulch application</li>
            <li>✓ Soil preparation</li>
            <li>✓ Weeding</li>
          </ul>
        </div>

        <div class="bg-white rounded-lg shadow-lg p-6">
          <h3 class="text-2xl font-bold mb-3">Health Assessment</h3>
          <p class="text-gray-700 mb-4">
            Comprehensive evaluation of tree health to identify any issues and create treatment plans.
          </p>
          <ul class="space-y-2 text-gray-700 text-sm">
            <li>✓ Pest inspection</li>
            <li>✓ Disease screening</li>
            <li>✓ Nutrient evaluation</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Spring Hazards -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Common Spring Tree Hazards</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-blue-50 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-2">Winter Storm Damage</h3>
          <p class="text-gray-700">Heavy snow and wind break branches. Assess and remove dangerous limbs early.</p>
        </div>
        <div class="bg-blue-50 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-2">Pest Awakening</h3>
          <p class="text-gray-700">Spring pests like aphids and beetles become active. Preventive treatment helps.</p>
        </div>
        <div class="bg-blue-50 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-2">Spring Fungal Diseases</h3>
          <p class="text-gray-700">Wet spring weather promotes fungal disease. Early treatment is crucial.</p>
        </div>
        <div class="bg-blue-50 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-2">Drought Stress</h3>
          <p class="text-gray-700">Spring droughts in Denver affect tree health. Proper watering and care help.</p>
        </div>
      </div>
    </section>

    <!-- Why Spring Service -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Why Spring is the Best Time</h2>
      <div class="bg-green-50 rounded-lg p-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="text-center">
            <div class="text-4xl mb-3">🌱</div>
            <h3 class="text-xl font-bold mb-2">Before Growth Starts</h3>
            <p class="text-gray-700">Work before new growth begins allows trees to grow properly.</p>
          </div>
          <div class="text-center">
            <div class="text-4xl mb-3">🔍</div>
            <h3 class="text-xl font-bold mb-2">Assess Damage</h3>
            <p class="text-gray-700">Winter damage is visible and can be addressed before growth.</p>
          </div>
          <div class="text-center">
            <div class="text-4xl mb-3">🛡️</div>
            <h3 class="text-xl font-bold mb-2">Prevent Problems</h3>
            <p class="text-gray-700">Early treatment prevents pest and disease issues all season.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Denver Spring Conditions -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Denver Spring Tree Care</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
        <div>
          <h3 class="text-2xl font-bold mb-4">Understanding Denver's Spring</h3>
          <p class="text-lg text-gray-700 mb-4">
            Denver's spring brings unpredictable weather - from late snow to early heat waves. This stresses trees and creates opportunities for pests and disease.
          </p>
          <ul class="space-y-3 text-gray-700 mb-6">
            <li className="flex items-start">
              <span className="mr-3 text-2xl text-green-600">•</span>
              <span><strong>Late spring snows:</strong> Can break branches on leafing trees</span>
            </li>
            <li className="flex items-start">
              <span className="mr-3 text-2xl text-green-600">•</span>
              <span><strong>Temperature swings:</strong> Damage new growth and stress trees</span>
            </li>
            <li className="flex items-start">
              <span className="mr-3 text-2xl text-green-600">•</span>
              <span><strong>Dry conditions:</strong> Denver spring is often dry, stressing young growth</span>
            </li>
            <li className="flex items-start">
              <span className="mr-3 text-2xl text-green-600">•</span>
              <span><strong>High altitude UV:</strong> Intense spring sun can damage leaves</span>
            </li>
          </ul>
          <p class="text-lg text-gray-700">
            Our spring cleanup and care services address these unique Denver conditions.
          </p>
        </div>
        <div class="bg-white rounded-lg shadow-lg p-6">
          <h3 class="text-xl font-bold mb-4">Spring Checklist</h3>
          <ul class="space-y-3 text-gray-700">
            <li class="flex items-start">
              <input type="checkbox" checked disabled class="mr-3 mt-1" />
              <span>Assess winter storm damage</span>
            </li>
            <li class="flex items-start">
              <input type="checkbox" checked disabled class="mr-3 mt-1" />
              <span>Remove dead or dying branches</span>
            </li>
            <li class="flex items-start">
              <input type="checkbox" checked disabled class="mr-3 mt-1" />
              <span>Apply preventive pest treatment</span>
            </li>
            <li class="flex items-start">
              <input type="checkbox" checked disabled class="mr-3 mt-1" />
              <span>Treat early disease issues</span>
            </li>
            <li class="flex items-start">
              <input type="checkbox" checked disabled class="mr-3 mt-1" />
              <span>Mulch and water as needed</span>
            </li>
            <li class="flex items-start">
              <input type="checkbox" checked disabled class="mr-3 mt-1" />
              <span>Schedule health assessment</span>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="bg-green-600 text-white py-12 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-4xl font-bold mb-4">Get Your Spring Cleanup Started</h2>
        <p class="text-xl mb-8">Schedule your spring tree assessment and cleanup today.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="tel:+13039496818" class="bg-white text-green-600 px-8 py-3 rounded-lg font-bold hover:bg-gray-100 transition flex items-center justify-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            Call (303) 949-6818
          </a>
          <EstimateButton client:load className="bg-white text-green-600 px-8 py-3 rounded-lg font-bold hover:bg-gray-100 transition">
            Get Free Assessment
          </EstimateButton>
        </div>
      </div>
    </section>
  </main>

  <Footer slot="footer" />
</Layout>
