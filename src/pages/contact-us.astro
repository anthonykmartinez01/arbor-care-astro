---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.tsx";
import Footer from "../components/Footer.astro";
import EstimateEmbed from "../components/EstimateEmbed.tsx";
---

<Layout title="Contact Us | Arbor Care Tree Solutions Denver" description="Contact Arbor Care Tree Solutions in Denver, CO. Call (303) 949-6818, email, or fill out our form for a free estimate. We answer 24/7." canonical="/contact-us">
  <Header slot="header" pathname="/contact-us" client:load />

  <main class="min-h-screen">
    <!-- Hero Section -->
    <section
      class="relative h-96 bg-cover bg-center flex items-center justify-center"
      style="background-image: url('/assets/contact-hero.jpg');"
    >
      <div class="absolute inset-0 bg-black/40"></div>
      <div class="relative z-10 text-center text-white px-4">
        <h1 class="text-5xl md:text-6xl font-bold mb-4">Contact Us</h1>
        <p class="text-xl md:text-2xl">Get Your Free Estimate Today</p>
      </div>
    </section>

    <!-- Contact Information -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
        <!-- Phone -->
        <div class="bg-white rounded-lg shadow-lg p-6 text-center">
          <div class="flex justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-600"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          </div>
          <h3 class="text-xl font-bold mb-2">Phone</h3>
          <a href="tel:+13039496818" class="text-green-600 hover:text-green-700 font-semibold text-lg">
            (303) 949-6818
          </a>
          <p class="text-gray-600 text-sm mt-2">Available 24/7</p>
        </div>

        <!-- Email -->
        <div class="bg-white rounded-lg shadow-lg p-6 text-center">
          <div class="flex justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-600"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
          </div>
          <h3 class="text-xl font-bold mb-2">Email</h3>
          <a href="mailto:ArborCareTreeSolutions@gmail.com" class="text-green-600 hover:text-green-700 font-semibold break-all">
            ArborCareTreeSolutions@gmail.com
          </a>
          <p class="text-gray-600 text-sm mt-2">We'll respond quickly</p>
        </div>

        <!-- Location -->
        <div class="bg-white rounded-lg shadow-lg p-6 text-center">
          <div class="flex justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-600"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
          </div>
          <h3 class="text-xl font-bold mb-2">Location</h3>
          <p class="text-gray-700 font-semibold">
            1130 S Santa Fe Dr<br />
            Denver, CO 80223
          </p>
        </div>

        <!-- Hours -->
        <div class="bg-white rounded-lg shadow-lg p-6 text-center">
          <div class="flex justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-600"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
          </div>
          <h3 class="text-xl font-bold mb-2">Hours</h3>
          <p class="text-gray-700 font-semibold">
            24/7 Service<br />
            Emergency Response
          </p>
        </div>
      </div>
    </section>

    <!-- Contact Form -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Get Your Free Estimate</h2>
      <div class="bg-white rounded-lg shadow-lg p-8">
        <EstimateEmbed client:visible />
      </div>
    </section>

    <!-- Service Areas -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Service Areas</h2>
      <p class="text-lg text-gray-700 mb-8 text-center">
        We proudly serve Denver and the surrounding metro area with professional tree care services.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-blue-50 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-4">Denver Area</h3>
          <ul class="space-y-2 text-gray-700 text-sm">
            <li>• Downtown Denver</li>
            <li>• Capitol Hill</li>
            <li>• Washington Park</li>
            <li>• Cherry Creek</li>
            <li>• South Platte</li>
          </ul>
        </div>
        <div class="bg-blue-50 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-4">South Denver</h3>
          <ul class="space-y-2 text-gray-700 text-sm">
            <li>• Aurora</li>
            <li>• Littleton</li>
            <li>• Englewood</li>
            <li>• Castle Rock</li>
            <li>• Highlands Ranch</li>
          </ul>
        </div>
        <div class="bg-blue-50 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-4">Denver Metro</h3>
          <ul class="space-y-2 text-gray-700 text-sm">
            <li>• Westminster</li>
            <li>• Broomfield</li>
            <li>• Thornton</li>
            <li>• Arvada</li>
            <li>• Boulder Area</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Google Maps -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Our Location</h2>
      <div class="rounded-lg overflow-hidden shadow-lg" style="height: 400px;">
        <iframe
          width="100%"
          height="400"
          style="border:0"
          loading="lazy"
          allowfullscreen=""
          referrerpolicy="no-referrer-when-downgrade"
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3069.3814234572647!2d-104.90819!3d39.680453!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x876b8df79e9ce9f9%3A0x4b4f8c8d8c8d8c8d!2sArbor%20Care%20Tree%20Solutions!5e0!3m2!1sen!2sus!4v1234567890"
        ></iframe>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Frequently Asked Questions</h2>
      <div class="space-y-6">
        <div class="bg-gray-50 rounded-lg p-6">
          <h3 class="text-xl font-bold mb-3">Do you offer free estimates?</h3>
          <p class="text-gray-700">Yes, we provide free, no-obligation estimates for all our services. There is no trip charge for the estimate.</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-6">
          <h3 class="text-xl font-bold mb-3">Are you available for emergency services?</h3>
          <p class="text-gray-700">Yes, we provide 24/7 emergency tree removal and storm damage response. Call (303) 949-6818 anytime.</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-6">
          <h3 class="text-xl font-bold mb-3">What areas do you service?</h3>
          <p class="text-gray-700">We serve Denver and the surrounding metro area, including Aurora, Littleton, Englewood, Boulder, and many other communities.</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-6">
          <h3 class="text-xl font-bold mb-3">How do I schedule a service?</h3>
          <p class="text-gray-700">You can call us at (303) 949-6818, email us at ArborCareTreeSolutions@gmail.com, or fill out the estimate form on this page.</p>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="bg-green-600 text-white py-12 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-4xl font-bold mb-4">Ready to Improve Your Trees?</h2>
        <p class="text-xl mb-8">Contact us today for your free estimate. We're here to help!</p>
        <a href="tel:+13039496818" class="bg-white text-green-600 px-8 py-3 rounded-lg font-bold hover:bg-gray-100 transition inline-flex items-center justify-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          Call (303) 949-6818
        </a>
      </div>
    </section>
  </main>

  <Footer slot="footer" />
</Layout>
