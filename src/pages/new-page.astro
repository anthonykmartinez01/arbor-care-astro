---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.tsx";
import Footer from "../components/Footer.astro";
import { EstimateButton } from "../components/EstimateModal.tsx";
---

<Layout title="Holiday Lights Installation Denver CO | Arbor Care" description="Professional holiday light installation in Denver, CO. Let your tree service handle the heights. Book early for the season." canonical="/new-page">
  <Header slot="header" pathname="/new-page" client:load />

  <main class="min-h-screen">
    <!-- Hero Section -->
    <section class="bg-gradient-to-r from-red-600 to-green-600 text-white py-16 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-5xl md:text-6xl font-bold mb-4">
          <span class="inline-block">✨</span> Holiday Lights Installation <span class="inline-block">✨</span>
        </h1>
        <p class="text-xl md:text-2xl">Professional Light Installation for Your Denver Home</p>
      </div>
    </section>

    <!-- Introduction -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <div class="prose prose-lg max-w-none">
        <p class="text-lg text-gray-700 mb-6">
          Let your professional tree service handle the heights this holiday season. Arbor Care Tree Solutions offers safe, professional holiday light installation for Denver homes. From roof lines to tall trees, we have the expertise and equipment to transform your home into a winter wonderland.
        </p>
      </div>
    </section>

    <!-- Why Choose Us for Holiday Lights -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Why Choose Arbor Care for Holiday Lights?</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-red-50 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-2">Safety First</h3>
          <p class="text-gray-700">We have the proper equipment and training for safe installation at heights. No DIY accidents.</p>
        </div>
        <div class="bg-red-50 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-2">Professional Quality</h3>
          <p class="text-gray-700">Beautiful, evenly spaced installations with attention to detail and proper securing.</p>
        </div>
        <div class="bg-red-50 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-2">Experienced Team</h3>
          <p class="text-gray-700">We work at heights safely every day in our tree care business.</p>
        </div>
        <div class="bg-red-50 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-2">Fully Insured</h3>
          <p class="text-gray-700">Complete liability insurance protects you and your property.</p>
        </div>
      </div>
    </section>

    <!-- Services Offered -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Holiday Light Services</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white rounded-lg shadow-lg p-6">
          <h3 class="text-2xl font-bold mb-3">Roof & Gutter Installation</h3>
          <p class="text-gray-700 mb-4">
            Professional installation of lights along rooflines and gutters with proper securing and safety measures.
          </p>
          <ul class="space-y-2 text-gray-700 text-sm">
            <li>✓ Gutter lights</li>
            <li>✓ Roof line installation</li>
            <li>✓ Fascia lighting</li>
          </ul>
        </div>

        <div class="bg-white rounded-lg shadow-lg p-6">
          <h3 class="text-2xl font-bold mb-3">Tree & Shrub Lighting</h3>
          <p class="text-gray-700 mb-4">
            Professional light installation in trees and shrubs for stunning landscape lighting effects.
          </p>
          <ul class="space-y-2 text-gray-700 text-sm">
            <li>✓ Tree wrapping</li>
            <li>✓ Shrub lighting</li>
            <li>✓ Accent uplighting</li>
          </ul>
        </div>

        <div class="bg-white rounded-lg shadow-lg p-6">
          <h3 class="text-2xl font-bold mb-3">Design & Consultation</h3>
          <p class="text-gray-700 mb-4">
            Expert advice on light placement, color schemes, and design for maximum visual impact.
          </p>
          <ul class="space-y-2 text-gray-700 text-sm">
            <li>✓ Design consultation</li>
            <li>✓ Custom layouts</li>
            <li>✓ Lighting advice</li>
          </ul>
        </div>

        <div class="bg-white rounded-lg shadow-lg p-6">
          <h3 class="text-2xl font-bold mb-3">Removal & Storage</h3>
          <p class="text-gray-700 mb-4">
            Professional removal after the holidays with proper storage of lights and equipment.
          </p>
          <ul class="space-y-2 text-gray-700 text-sm">
            <li>✓ Safe removal</li>
            <li>✓ Light storage</li>
            <li>✓ Clean up</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Safety & Quality -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Our Safety & Quality Standards</h2>
      <div class="bg-blue-50 rounded-lg p-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div>
            <h3 class="text-2xl font-bold mb-4">Safety Measures</h3>
            <ul class="space-y-3 text-gray-700">
              <li class="flex items-start">
                <span class="mr-3 text-2xl text-green-600">✓</span>
                <span>Professional climbing equipment</span>
              </li>
              <li class="flex items-start">
                <span class="mr-3 text-2xl text-green-600">✓</span>
                <span>Proper harness and safety gear</span>
              </li>
              <li class="flex items-start">
                <span class="mr-3 text-2xl text-green-600">✓</span>
                <span>Electrical safety standards</span>
              </li>
              <li class="flex items-start">
                <span class="mr-3 text-2xl text-green-600">✓</span>
                <span>Secure installations that won't blow down</span>
              </li>
            </ul>
          </div>
          <div>
            <h3 class="text-2xl font-bold mb-4">Quality Installation</h3>
            <ul class="space-y-3 text-gray-700">
              <li class="flex items-start">
                <span class="mr-3 text-2xl text-green-600">✓</span>
                <span>Even light spacing and alignment</span>
              </li>
              <li class="flex items-start">
                <span class="mr-3 text-2xl text-green-600">✓</span>
                <span>Professional-grade materials</span>
              </li>
              <li class="flex items-start">
                <span class="mr-3 text-2xl text-green-600">✓</span>
                <span>Weatherproof connections</span>
              </li>
              <li class="flex items-start">
                <span class="mr-3 text-2xl text-green-600">✓</span>
                <span>Year-round lighting options</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Booking Information -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Booking Your Holiday Lights</h2>
      <div class="bg-yellow-50 border-2 border-yellow-400 rounded-lg p-8">
        <h3 class="text-2xl font-bold mb-4">Early Booking Recommended</h3>
        <p class="text-lg text-gray-700 mb-4">
          The holiday season is our busy time. <strong>Book early to secure your preferred installation date.</strong> We recommend scheduling in October or early November for November/December installation.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-white p-4 rounded-lg">
            <h4 class="font-bold mb-2">October-November</h4>
            <p class="text-gray-700 text-sm">Peak booking period. Call early for best dates.</p>
          </div>
          <div class="bg-white p-4 rounded-lg">
            <h4 class="font-bold mb-2">November-December</h4>
            <p class="text-gray-700 text-sm">Holiday season installations. Book ASAP.</p>
          </div>
          <div class="bg-white p-4 rounded-lg">
            <h4 class="font-bold mb-2">January</h4>
            <p class="text-gray-700 text-sm">Removal and takedown services available.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="bg-green-600 text-white py-12 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-4xl font-bold mb-4">Schedule Your Holiday Light Installation</h2>
        <p class="text-xl mb-8">Book early for the best dates. Call today or fill out a quote request.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="tel:+13039496818" class="bg-white text-green-600 px-8 py-3 rounded-lg font-bold hover:bg-gray-100 transition flex items-center justify-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            Call (303) 949-6818
          </a>
          <EstimateButton client:load className="bg-white text-green-600 px-8 py-3 rounded-lg font-bold hover:bg-gray-100 transition">
            Get Free Quote
          </EstimateButton>
        </div>
      </div>
    </section>
  </main>

  <Footer slot="footer" />
</Layout>
