---
import BaseLayout from "../components/layout/BaseLayout.astro";
import { coreServices, secondaryCategories, generalServices } from "../data/services";

const mainPages = [
  { label: "Home", to: "/" },
  { label: "Tree Services", to: "/tree-services" },
  { label: "Our Work", to: "/our-work" },
  { label: "Testimonials", to: "/testimonials" },
  { label: "About Us", to: "/about-arbor-care-index" },
  { label: "Contact", to: "/contact-us" },
  { label: "Free Estimates", to: "/new-index-2" },
  { label: "Holiday Lights & Decor", to: "/new-page" },
  { label: "Spring Cleanup & Treatments", to: "/treatments" },
  { label: "We're Hiring", to: "/were-hiring" },
];
---

<BaseLayout
  title="Sitemap | Arbor Care Tree Solutions Denver CO"
  description="Complete directory of all Arbor Care Tree Solutions pages - tree services, arborist care, firewood, seasonal services, and more in Denver CO."
>
  <section class="py-16 md:py-24">
    <div class="container max-w-4xl">
      <h1 class="text-3xl md:text-4xl font-bold font-[Merriweather,serif] text-primary mb-10">
        Sitemap
      </h1>

      <div class="space-y-10">
        <!-- Main Pages -->
        <div>
          <h2 class="text-xl font-semibold mb-3">Main Pages</h2>
          <ul class="space-y-1.5 text-sm">
            {mainPages.map((p) => (
              <li>
                <a href={p.to} class="text-primary hover:underline">{p.label}</a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Service Categories -->
        {[...coreServices, ...secondaryCategories].map((cat) => (
          <div>
            <h2 class="text-xl font-semibold mb-3">
              <a href={cat.path} class="text-primary hover:underline">{cat.title}</a>
            </h2>
            <ul class="space-y-1.5 text-sm pl-4">
              {cat.children.map((child) => (
                <li>
                  <a href={child.path} class="text-primary hover:underline">{child.title}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}

        <!-- General Services -->
        <div>
          <h2 class="text-xl font-semibold mb-3">Additional Services</h2>
          <ul class="space-y-1.5 text-sm">
            {generalServices.map((s) => (
              <li>
                <a href={s.path} class="text-primary hover:underline">{s.title}</a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Other -->
        <div>
          <h2 class="text-xl font-semibold mb-3">Other</h2>
          <ul class="space-y-1.5 text-sm">
            <li><a href="/privacy-policy" class="text-primary hover:underline">Privacy Policy</a></li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
