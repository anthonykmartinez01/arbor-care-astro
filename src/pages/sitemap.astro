---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.tsx";
import Footer from "../components/Footer.astro";
---

<Layout title="Sitemap | Arbor Care Tree Solutions" description="Complete sitemap for Arbor Care Tree Solutions website." canonical="/sitemap">
  <Header slot="header" pathname="/sitemap" client:load />

  <main class="min-h-screen">
    <!-- Hero Section -->
    <section class="bg-gradient-to-r from-green-600 to-green-800 text-white py-16 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-5xl md:text-6xl font-bold mb-4">Sitemap</h1>
        <p class="text-xl md:text-2xl">Complete Directory of Arbor Care Pages</p>
      </div>
    </section>

    <!-- Content -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

        <!-- Main Pages -->
        <div>
          <h2 class="text-2xl font-bold mb-4 text-green-600">Main Pages</h2>
          <ul class="space-y-2">
            <li><a href="/" class="text-green-600 hover:text-green-700 hover:underline">Home</a></li>
            <li><a href="/about-arbor-care-index" class="text-green-600 hover:text-green-700 hover:underline">About Us</a></li>
            <li><a href="/contact-us" class="text-green-600 hover:text-green-700 hover:underline">Contact Us</a></li>
            <li><a href="/our-work" class="text-green-600 hover:text-green-700 hover:underline">Our Work</a></li>
            <li><a href="/testimonials" class="text-green-600 hover:text-green-700 hover:underline">Testimonials</a></li>
          </ul>
        </div>

        <!-- Services -->
        <div>
          <h2 class="text-2xl font-bold mb-4 text-green-600">Services</h2>
          <ul class="space-y-2">
            <li><a href="/tree-services" class="text-green-600 hover:text-green-700 hover:underline">All Services</a></li>
            <li><a href="/new-index-2" class="text-green-600 hover:text-green-700 hover:underline">Free Estimates</a></li>
          </ul>
        </div>

        <!-- Tree Trimming Services -->
        <div>
          <h2 class="text-2xl font-bold mb-4 text-green-600">Tree Trimming & Pruning</h2>
          <ul class="space-y-2">
            <li><a href="/tree-trimming" class="text-green-600 hover:text-green-700 hover:underline">Tree Trimming</a></li>
            <li><a href="/crown-reduction-denver-co" class="text-green-600 hover:text-green-700 hover:underline">Crown Reduction</a></li>
            <li><a href="/deadwooding-denver-co" class="text-green-600 hover:text-green-700 hover:underline">Deadwooding</a></li>
            <li><a href="/bush-shrub-trimming-denver-co" class="text-green-600 hover:text-green-700 hover:underline">Bush & Shrub Trimming</a></li>
          </ul>
        </div>

        <!-- Tree Removal Services -->
        <div>
          <h2 class="text-2xl font-bold mb-4 text-green-600">Tree Removal</h2>
          <ul class="space-y-2">
            <li><a href="/tree-removal" class="text-green-600 hover:text-green-700 hover:underline">Tree Removal</a></li>
            <li><a href="/emergency-tree-removal-denver-co" class="text-green-600 hover:text-green-700 hover:underline">Emergency Removal</a></li>
            <li><a href="/hazardous-tree-removal-denver-co" class="text-green-600 hover:text-green-700 hover:underline">Hazardous Tree Removal</a></li>
            <li><a href="/bush-shrub-removal-denver-co" class="text-green-600 hover:text-green-700 hover:underline">Bush & Shrub Removal</a></li>
          </ul>
        </div>

        <!-- Stump Grinding -->
        <div>
          <h2 class="text-2xl font-bold mb-4 text-green-600">Stump Grinding</h2>
          <ul class="space-y-2">
            <li><a href="/stump-grinding-denver-co" class="text-green-600 hover:text-green-700 hover:underline">Stump Grinding</a></li>
            <li><a href="/stump-removal-denver-co" class="text-green-600 hover:text-green-700 hover:underline">Stump Removal</a></li>
          </ul>
        </div>

        <!-- Arborist Services -->
        <div>
          <h2 class="text-2xl font-bold mb-4 text-green-600">Arborist Services</h2>
          <ul class="space-y-2">
            <li><a href="/arborist-service-denver-co" class="text-green-600 hover:text-green-700 hover:underline">Arborist Services</a></li>
            <li><a href="/tree-health-assessment-denver-co" class="text-green-600 hover:text-green-700 hover:underline">Tree Health Assessment</a></li>
            <li><a href="/tree-treatment-denver-co" class="text-green-600 hover:text-green-700 hover:underline">Tree Treatment</a></li>
            <li><a href="/tree-planting-denver-co" class="text-green-600 hover:text-green-700 hover:underline">Tree Planting</a></li>
          </ul>
        </div>

        <!-- Firewood Services -->
        <div>
          <h2 class="text-2xl font-bold mb-4 text-green-600">Firewood Supply</h2>
          <ul class="space-y-2">
            <li><a href="/other-services" class="text-green-600 hover:text-green-700 hover:underline">Firewood Supply</a></li>
            <li><a href="/seasoned-firewood-denver-co" class="text-green-600 hover:text-green-700 hover:underline">Seasoned Firewood</a></li>
            <li><a href="/firewood-delivery-denver-co" class="text-green-600 hover:text-green-700 hover:underline">Firewood Delivery</a></li>
          </ul>
        </div>

        <!-- Additional Services -->
        <div>
          <h2 class="text-2xl font-bold mb-4 text-green-600">Additional Services</h2>
          <ul class="space-y-2">
            <li><a href="/new-page" class="text-green-600 hover:text-green-700 hover:underline">Holiday Lights</a></li>
            <li><a href="/treatments" class="text-green-600 hover:text-green-700 hover:underline">Spring Cleanup</a></li>
            <li><a href="/were-hiring" class="text-green-600 hover:text-green-700 hover:underline">We're Hiring</a></li>
          </ul>
        </div>

        <!-- Legal & Information -->
        <div>
          <h2 class="text-2xl font-bold mb-4 text-green-600">Legal & Information</h2>
          <ul class="space-y-2">
            <li><a href="/privacy-policy" class="text-green-600 hover:text-green-700 hover:underline">Privacy Policy</a></li>
            <li><a href="/thank-you" class="text-green-600 hover:text-green-700 hover:underline">Thank You</a></li>
            <li><a href="/sitemap" class="text-green-600 hover:text-green-700 hover:underline">Sitemap</a></li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Quick Links Section -->
    <section class="bg-green-50 py-12 px-4 mt-12">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold mb-8 text-center">Quick Links</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <a href="tel:+13039496818" class="bg-white rounded-lg shadow p-4 text-center hover:shadow-lg transition">
            <div class="text-3xl mb-2">📞</div>
            <div class="font-bold text-gray-800">Call Us</div>
            <div class="text-sm text-gray-600">(303) 949-6818</div>
          </a>
          <a href="mailto:ArborCareTreeSolutions@gmail.com" class="bg-white rounded-lg shadow p-4 text-center hover:shadow-lg transition">
            <div class="text-3xl mb-2">✉️</div>
            <div class="font-bold text-gray-800">Email Us</div>
            <div class="text-sm text-gray-600">Get in Touch</div>
          </a>
          <a href="/contact-us" class="bg-white rounded-lg shadow p-4 text-center hover:shadow-lg transition">
            <div class="text-3xl mb-2">📍</div>
            <div class="font-bold text-gray-800">Visit</div>
            <div class="text-sm text-gray-600">Denver, CO</div>
          </a>
          <a href="/new-index-2" class="bg-white rounded-lg shadow p-4 text-center hover:shadow-lg transition">
            <div class="text-3xl mb-2">✓</div>
            <div class="font-bold text-gray-800">Estimate</div>
            <div class="text-sm text-gray-600">Free Quote</div>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer slot="footer" />
</Layout>
