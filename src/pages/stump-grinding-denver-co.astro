---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.tsx";
import Footer from "../components/Footer.astro";
import { EstimateButton } from "../components/EstimateModal.tsx";
---

<Layout title="Stump Grinding Denver CO | Fast & Professional | Arbor Care" description="Professional stump grinding in Denver, CO. Below-grade grinding, root removal options. Free estimates. Call (303) 949-6818." canonical="/stump-grinding-denver-co">
  <Header slot="header" pathname="/stump-grinding-denver-co" client:load />

  <main class="min-h-screen">
    <!-- Hero Section -->
    <section
      class="relative h-96 bg-cover bg-center flex items-center justify-center"
      style="background-image: url('/assets/hero-stump-grinding.jpg');"
    >
      <div class="absolute inset-0 bg-black/40"></div>
      <div class="relative z-10 text-center text-white px-4">
        <h1 class="text-5xl md:text-6xl font-bold mb-4">Professional Stump Grinding</h1>
        <p class="text-xl md:text-2xl">Fast & Efficient Stump Removal</p>
      </div>
    </section>

    <!-- Introduction -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <div class="prose prose-lg max-w-none">
        <p class="text-lg text-gray-700 mb-6">
          After tree removal, you're left with an unsightly stump that can be a tripping hazard and attract pests. Arbor Care Tree Solutions provides professional stump grinding services to eliminate stumps completely. Our modern equipment can grind stumps below grade level, leaving your landscape clean and ready for new plantings or other uses.
        </p>
      </div>
    </section>

    <!-- Signs You Need Stump Grinding -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Signs You Need Stump Grinding</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-amber-50 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-2">Unsightly Appearance</h3>
          <p class="text-gray-700">Tree stumps detract from your landscape's appearance and curb appeal.</p>
        </div>
        <div class="bg-amber-50 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-2">Safety Hazard</h3>
          <p class="text-gray-700">Stumps create tripping hazards, especially in yards with children or pets.</p>
        </div>
        <div class="bg-amber-50 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-2">Pest Attraction</h3>
          <p class="text-gray-700">Decaying stumps attract termites, ants, and other wood-boring insects.</p>
        </div>
        <div class="bg-amber-50 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-2">Space Reclamation</h3>
          <p class="text-gray-700">Grinding allows you to use the space for new landscaping or construction.</p>
        </div>
      </div>
    </section>

    <!-- Service Options -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Our Stump Services</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white rounded-lg shadow-lg overflow-hidden">
          <div class="bg-amber-700 h-24 flex items-center justify-center">
            <span class="text-white text-3xl">⚙️</span>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold mb-2">Commercial Stump Grinding</h3>
            <p class="text-gray-600 mb-4">Professional grinding services for residential and commercial properties.</p>
          </div>
        </div>

        <div class="bg-white rounded-lg shadow-lg overflow-hidden">
          <div class="bg-amber-700 h-24 flex items-center justify-center">
            <span class="text-white text-3xl">🚚</span>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold mb-2"><a href="/stump-removal-denver-co" class="text-green-600 hover:text-green-700">Stump Removal</a></h3>
            <p class="text-gray-600 mb-4">Complete stump removal with root extraction and cleanup.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Denver Specific Section -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Denver Stump Grinding Expertise</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
        <div>
          <h3 class="text-2xl font-bold mb-4">Below-Grade Grinding</h3>
          <p class="text-lg text-gray-700 mb-4">
            Our professional-grade equipment can grind stumps up to 12 inches below grade level, completely eliminating the stump and making the space level with your lawn.
          </p>
          <p class="text-lg text-gray-700 mb-4">
            We handle Denver's rocky soil and difficult stumps efficiently and safely.
          </p>
          <p class="text-lg text-gray-700">
            After grinding, you're left with wood chips that can be used for mulch or removed from your property.
          </p>
        </div>
        <div>
          <img src="/assets/hero-climber.jpg" alt="Professional stump grinding equipment" class="rounded-lg shadow-lg" />
        </div>
      </div>
    </section>

    <!-- What to Expect -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">What to Expect From Our Service</h2>
      <div class="space-y-4">
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 bg-green-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
          <div>
            <h3 class="text-xl font-bold mb-2">Site Preparation</h3>
            <p class="text-gray-700">We assess the stump location and prepare the area for safe grinding.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 bg-green-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
          <div>
            <h3 class="text-xl font-bold mb-2">Professional Grinding</h3>
            <p class="text-gray-700">We use modern equipment to grind the stump below grade level.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 bg-green-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
          <div>
            <h3 class="text-xl font-bold mb-2">Chip Removal</h3>
            <p class="text-gray-700">We can remove or leave wood chips for use as mulch.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 bg-green-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
          <div>
            <h3 class="text-xl font-bold mb-2">Site Cleanup</h3>
            <p class="text-gray-700">Your property is left clean and level, ready for new use.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Choose Us -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Why Choose Arbor Care?</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="text-center">
          <div class="text-5xl mb-4">🏆</div>
          <h3 class="text-xl font-bold mb-2">Professional Equipment</h3>
          <p class="text-gray-700">Modern grinders capable of below-grade grinding.</p>
        </div>
        <div class="text-center">
          <div class="text-5xl mb-4">📋</div>
          <h3 class="text-xl font-bold mb-2">Licensed & Insured</h3>
          <p class="text-gray-700">Fully licensed and insured for your protection.</p>
        </div>
        <div class="text-center">
          <div class="text-5xl mb-4">⚡</div>
          <h3 class="text-xl font-bold mb-2">Quick Service</h3>
          <p class="text-gray-700">Fast and efficient grinding with minimal disruption.</p>
        </div>
        <div class="text-center">
          <div class="text-5xl mb-4">💰</div>
          <h3 class="text-xl font-bold mb-2">Free Estimates</h3>
          <p class="text-gray-700">No obligation, no trip charge for your estimate.</p>
        </div>
        <div class="text-center">
          <div class="text-5xl mb-4">🎯</div>
          <h3 class="text-xl font-bold mb-2">Expert Service</h3>
          <p class="text-gray-700">Years of experience in all types of stump grinding.</p>
        </div>
        <div class="text-center">
          <div class="text-5xl mb-4">🏘️</div>
          <h3 class="text-xl font-bold mb-2">Local Knowledge</h3>
          <p class="text-gray-700">Experience with Denver's soil and conditions.</p>
        </div>
      </div>
    </section>

    <!-- Related Services -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Related Services</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href="/tree-removal" class="bg-white rounded-lg shadow-lg p-6 hover:shadow-xl transition text-center">
          <h3 class="text-xl font-bold mb-2 text-green-600">Tree Removal</h3>
          <p class="text-gray-600">Professional removal before stump grinding</p>
        </a>
        <a href="/tree-trimming" class="bg-white rounded-lg shadow-lg p-6 hover:shadow-xl transition text-center">
          <h3 class="text-xl font-bold mb-2 text-green-600">Tree Trimming</h3>
          <p class="text-gray-600">Preventive tree care services</p>
        </a>
        <a href="/arborist-service-denver-co" class="bg-white rounded-lg shadow-lg p-6 hover:shadow-xl transition text-center">
          <h3 class="text-xl font-bold mb-2 text-green-600">Arborist Services</h3>
          <p class="text-gray-600">Tree health assessment</p>
        </a>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="bg-green-600 text-white py-12 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-4xl font-bold mb-4">Ready to Remove Your Stumps?</h2>
        <p class="text-xl mb-8">Get your free estimate for professional stump grinding today.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="tel:+13039496818" class="bg-white text-green-600 px-8 py-3 rounded-lg font-bold hover:bg-gray-100 transition flex items-center justify-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            Call (303) 949-6818
          </a>
          <EstimateButton client:load className="bg-white text-green-600 px-8 py-3 rounded-lg font-bold hover:bg-gray-100 transition">
            Get Free Estimate
          </EstimateButton>
        </div>
      </div>
    </section>
  </main>

  <Footer slot="footer" />
</Layout>
