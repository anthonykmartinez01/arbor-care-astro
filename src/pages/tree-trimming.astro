---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.tsx";
import Footer from "../components/Footer.astro";
import { EstimateButton } from "../components/EstimateModal.tsx";
---

<Layout title="Tree Trimming Denver CO | Expert Pruning | Arbor Care" description="Professional tree trimming and pruning in Denver, CO. Crown reduction, deadwooding, bush & shrub trimming. ISA-certified arborists. Free estimates. Call (303) 949-6818." canonical="/tree-trimming">
  <Header slot="header" pathname="/tree-trimming" client:load />

  <main class="min-h-screen">
    <!-- Hero Section -->
    <section
      class="relative h-96 bg-cover bg-center flex items-center justify-center"
      style="background-image: url('/assets/hero-tree-trimming.jpg');"
    >
      <div class="absolute inset-0 bg-black/40"></div>
      <div class="relative z-10 text-center text-white px-4">
        <h1 class="text-5xl md:text-6xl font-bold mb-4">Professional Tree Trimming</h1>
        <p class="text-xl md:text-2xl">Expert Pruning Services in Denver</p>
      </div>
    </section>

    <!-- Introduction -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <div class="prose prose-lg max-w-none">
        <p class="text-lg text-gray-700 mb-6">
          Tree trimming and pruning are essential services that keep your trees healthy, attractive, and safe. At Arbor Care Tree Solutions, our ISA-certified arborists use proper techniques to enhance tree structure, encourage healthy growth, and prevent disease. Whether you need routine maintenance pruning or specialized crown reduction, we have the expertise to care for your trees.
        </p>
      </div>
    </section>

    <!-- Signs You Need Tree Trimming -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Signs You Need Tree Trimming & Pruning</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-blue-50 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-2">Overgrown Branches</h3>
          <p class="text-gray-700">Branches extending over roof lines, driveways, or walkways should be trimmed for safety and property protection.</p>
        </div>
        <div class="bg-blue-50 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-2">Dead or Diseased Limbs</h3>
          <p class="text-gray-700">Dead wood should be removed to prevent disease spread, improve appearance, and reduce hazard risks.</p>
        </div>
        <div class="bg-blue-50 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-2">Crossing Branches</h3>
          <p class="text-gray-700">Branches rubbing against each other can cause damage and create entry points for disease.</p>
        </div>
        <div class="bg-blue-50 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-2">Dense Canopy</h3>
          <p class="text-gray-700">Thick growth reduces light penetration and air circulation, promoting disease and pest problems.</p>
        </div>
      </div>
    </section>

    <!-- Service Options -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Our Trimming Services</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white rounded-lg shadow-lg overflow-hidden">
          <div class="bg-green-600 h-24 flex items-center justify-center">
            <span class="text-white text-3xl">👑</span>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold mb-2"><a href="/crown-reduction-denver-co" class="text-green-600 hover:text-green-700">Crown Reduction</a></h3>
            <p class="text-gray-600 mb-4">Strategically reduce tree size while maintaining natural form and health.</p>
          </div>
        </div>

        <div class="bg-white rounded-lg shadow-lg overflow-hidden">
          <div class="bg-green-600 h-24 flex items-center justify-center">
            <span class="text-white text-3xl">💀</span>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold mb-2"><a href="/deadwooding-denver-co" class="text-green-600 hover:text-green-700">Deadwooding</a></h3>
            <p class="text-gray-600 mb-4">Remove dead branches to improve appearance, prevent disease, and enhance safety.</p>
          </div>
        </div>

        <div class="bg-white rounded-lg shadow-lg overflow-hidden">
          <div class="bg-green-600 h-24 flex items-center justify-center">
            <span class="text-white text-3xl">🌿</span>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold mb-2"><a href="/bush-shrub-trimming-denver-co" class="text-green-600 hover:text-green-700">Bush & Shrub Trimming</a></h3>
            <p class="text-gray-600 mb-4">Professional trimming to shape and maintain your bushes and shrubs.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Denver Specific Section -->
    <section class="py-12 px-4">
      <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
        <div>
          <img src="/assets/hero-climber.jpg" alt="Arborist climbing tree" class="rounded-lg shadow-lg" />
        </div>
        <div>
          <h2 class="text-4xl font-bold mb-4">Denver Tree Trimming Expertise</h2>
          <p class="text-lg text-gray-700 mb-4">
            Denver's unique climate and tree species require specialized knowledge. Our ISA-certified arborists understand the specific needs of Denver's trees, including ponderosa pines, Douglas firs, and other local species.
          </p>
          <p class="text-lg text-gray-700">
            We follow ANSI A300 pruning standards to ensure your trees remain healthy, attractive, and safe for years to come.
          </p>
        </div>
      </div>
    </section>

    <!-- What to Expect -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">What to Expect From Our Service</h2>
      <div class="space-y-4">
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 bg-green-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
          <div>
            <h3 class="text-xl font-bold mb-2">Professional Assessment</h3>
            <p class="text-gray-700">Our arborists evaluate your tree's health, structure, and specific needs before trimming.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 bg-green-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
          <div>
            <h3 class="text-xl font-bold mb-2">Expert Trimming</h3>
            <p class="text-gray-700">We use proper pruning techniques and equipment to safely trim your trees.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 bg-green-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
          <div>
            <h3 class="text-xl font-bold mb-2">Cleanup</h3>
            <p class="text-gray-700">We remove all branches and debris, leaving your property clean.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 bg-green-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
          <div>
            <h3 class="text-xl font-bold mb-2">Maintenance Tips</h3>
            <p class="text-gray-700">We provide guidance on tree care and maintenance recommendations.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Choose Us -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Why Choose Arbor Care?</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="text-center">
          <div class="text-5xl mb-4">🏆</div>
          <h3 class="text-xl font-bold mb-2">ISA Certified</h3>
          <p class="text-gray-700">Our arborists are certified by the International Society of Arboriculture.</p>
        </div>
        <div class="text-center">
          <div class="text-5xl mb-4">📋</div>
          <h3 class="text-xl font-bold mb-2">Licensed & Insured</h3>
          <p class="text-gray-700">Fully licensed and insured for your peace of mind and protection.</p>
        </div>
        <div class="text-center">
          <div class="text-5xl mb-4">⚡</div>
          <h3 class="text-xl font-bold mb-2">Quick Response</h3>
          <p class="text-gray-700">We provide fast, reliable service with availability 24/7.</p>
        </div>
        <div class="text-center">
          <div class="text-5xl mb-4">💰</div>
          <h3 class="text-xl font-bold mb-2">Free Estimates</h3>
          <p class="text-gray-700">No obligation, no trip charge for your free estimate.</p>
        </div>
        <div class="text-center">
          <div class="text-5xl mb-4">🎯</div>
          <h3 class="text-xl font-bold mb-2">Expert Technique</h3>
          <p class="text-gray-700">We follow ANSI standards for proper and safe tree care.</p>
        </div>
        <div class="text-center">
          <div class="text-5xl mb-4">🏘️</div>
          <h3 class="text-xl font-bold mb-2">Local Knowledge</h3>
          <p class="text-gray-700">Deep understanding of Denver's trees and climate.</p>
        </div>
      </div>
    </section>

    <!-- Related Services -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Related Services</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href="/tree-removal" class="bg-white rounded-lg shadow-lg p-6 hover:shadow-xl transition text-center">
          <h3 class="text-xl font-bold mb-2 text-green-600">Tree Removal</h3>
          <p class="text-gray-600">Safe removal of hazardous or problem trees</p>
        </a>
        <a href="/stump-grinding-denver-co" class="bg-white rounded-lg shadow-lg p-6 hover:shadow-xl transition text-center">
          <h3 class="text-xl font-bold mb-2 text-green-600">Stump Grinding</h3>
          <p class="text-gray-600">Efficient stump removal and grinding</p>
        </a>
        <a href="/arborist-service-denver-co" class="bg-white rounded-lg shadow-lg p-6 hover:shadow-xl transition text-center">
          <h3 class="text-xl font-bold mb-2 text-green-600">Arborist Services</h3>
          <p class="text-gray-600">Tree health assessment and expert care</p>
        </a>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="bg-green-600 text-white py-12 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-4xl font-bold mb-4">Ready for Professional Tree Trimming?</h2>
        <p class="text-xl mb-8">Get your free estimate today from Denver's trusted tree service.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="tel:+13039496818" class="bg-white text-green-600 px-8 py-3 rounded-lg font-bold hover:bg-gray-100 transition flex items-center justify-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            Call (303) 949-6818
          </a>
          <EstimateButton client:load className="bg-white text-green-600 px-8 py-3 rounded-lg font-bold hover:bg-gray-100 transition">
            Get Free Estimate
          </EstimateButton>
        </div>
      </div>
    </section>
  </main>

  <Footer slot="footer" />
</Layout>
