---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.tsx";
import Footer from "../components/Footer.astro";
---

<Layout title="We're Hiring | Arbor Care Tree Solutions Denver" description="Join the Arbor Care Tree Solutions team in Denver, CO. We're looking for experienced tree care professionals." canonical="/were-hiring">
  <Header slot="header" pathname="/were-hiring" client:load />

  <main class="min-h-screen">
    <!-- Hero Section -->
    <section class="bg-gradient-to-r from-green-600 to-green-800 text-white py-16 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-5xl md:text-6xl font-bold mb-4">Join Our Team</h1>
        <p class="text-xl md:text-2xl">We're Hiring Experienced Tree Care Professionals</p>
      </div>
    </section>

    <!-- Introduction -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <div class="prose prose-lg max-w-none">
        <p class="text-lg text-gray-700 mb-6">
          Arbor Care Tree Solutions is growing, and we're looking for talented, dedicated professionals to join our team. If you love working outdoors, have tree care experience, and want to be part of a professional, family-oriented company, we'd like to hear from you.
        </p>
      </div>
    </section>

    <!-- Open Positions -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">We're Looking For</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white rounded-lg shadow-lg p-6">
          <h3 class="text-2xl font-bold mb-4">Experienced Arborists</h3>
          <p class="text-gray-700 mb-4">
            We're seeking experienced tree climbers and arborists with strong safety records and technical skills.
          </p>
          <ul class="space-y-2 text-gray-700 text-sm">
            <li>✓ ISA Certification preferred</li>
            <li>✓ Climbing experience required</li>
            <li>✓ Safety-focused mindset</li>
            <li>✓ Strong work ethic</li>
          </ul>
        </div>

        <div class="bg-white rounded-lg shadow-lg p-6">
          <h3 class="text-2xl font-bold mb-4">Equipment Operators</h3>
          <p class="text-gray-700 mb-4">
            Skilled operators for stump grinders, chippers, and other specialized tree care equipment.
          </p>
          <ul class="space-y-2 text-gray-700 text-sm">
            <li>✓ Equipment experience</li>
            <li>✓ Mechanical aptitude</li>
            <li>✓ Safety training</li>
            <li>✓ Reliable and punctual</li>
          </ul>
        </div>

        <div class="bg-white rounded-lg shadow-lg p-6">
          <h3 class="text-2xl font-bold mb-4">Ground Crew Members</h3>
          <p class="text-gray-700 mb-4">
            Hardworking team members to support tree care operations and maintain high quality standards.
          </p>
          <ul class="space-y-2 text-gray-700 text-sm">
            <li>✓ Physical fitness required</li>
            <li>✓ Team player attitude</li>
            <li>✓ Willingness to learn</li>
            <li>✓ Safety-conscious</li>
          </ul>
        </div>

        <div class="bg-white rounded-lg shadow-lg p-6">
          <h3 class="text-2xl font-bold mb-4">Crew Leads</h3>
          <p class="text-gray-700 mb-4">
            Experienced supervisors to lead crews, manage projects, and ensure quality and safety.
          </p>
          <ul class="space-y-2 text-gray-700 text-sm">
            <li>✓ Leadership experience</li>
            <li>✓ Project management skills</li>
            <li>✓ Customer service focus</li>
            <li>✓ Safety knowledge</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Who We're Looking For -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Ideal Candidates</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-green-50 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-4">Skills & Experience</h3>
          <ul class="space-y-3 text-gray-700">
            <li class="flex items-start">
              <span class="mr-3 text-2xl text-green-600">✓</span>
              <span>Tree care or landscaping experience</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3 text-2xl text-green-600">✓</span>
              <span>Knowledge of safety standards and protocols</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3 text-2xl text-green-600">✓</span>
              <span>Ability to work at heights safely</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3 text-2xl text-green-600">✓</span>
              <span>Strong problem-solving skills</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3 text-2xl text-green-600">✓</span>
              <span>Valid driver's license</span>
            </li>
          </ul>
        </div>

        <div class="bg-green-50 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-4">Personal Qualities</h3>
          <ul class="space-y-3 text-gray-700">
            <li class="flex items-start">
              <span class="mr-3 text-2xl text-green-600">✓</span>
              <span>Commitment to safety</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3 text-2xl text-green-600">✓</span>
              <span>Strong work ethic and reliability</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3 text-2xl text-green-600">✓</span>
              <span>Team player mentality</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3 text-2xl text-green-600">✓</span>
              <span>Customer service oriented</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3 text-2xl text-green-600">✓</span>
              <span>Willingness to learn and grow</span>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- What We Offer -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">What We Offer</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white rounded-lg shadow-lg p-6 text-center">
          <div class="text-4xl mb-4">💰</div>
          <h3 class="text-xl font-bold mb-2">Competitive Pay</h3>
          <p class="text-gray-700">Competitive wages based on experience and skills</p>
        </div>

        <div class="bg-white rounded-lg shadow-lg p-6 text-center">
          <div class="text-4xl mb-4">🏥</div>
          <h3 class="text-xl font-bold mb-2">Benefits</h3>
          <p class="text-gray-700">Health insurance, retirement planning, and more</p>
        </div>

        <div class="bg-white rounded-lg shadow-lg p-6 text-center">
          <div class="text-4xl mb-4">📚</div>
          <h3 class="text-xl font-bold mb-2">Training</h3>
          <p class="text-gray-700">Ongoing education and certification support</p>
        </div>

        <div class="bg-white rounded-lg shadow-lg p-6 text-center">
          <div class="text-4xl mb-4">🚗</div>
          <h3 class="text-xl font-bold mb-2">Equipment</h3>
          <p class="text-gray-700">Professional-grade tools and equipment provided</p>
        </div>

        <div class="bg-white rounded-lg shadow-lg p-6 text-center">
          <div class="text-4xl mb-4">🤝</div>
          <h3 class="text-xl font-bold mb-2">Family Culture</h3>
          <p class="text-gray-700">Supportive, professional team environment</p>
        </div>

        <div class="bg-white rounded-lg shadow-lg p-6 text-center">
          <div class="text-4xl mb-4">📈</div>
          <h3 class="text-xl font-bold mb-2">Growth</h3>
          <p class="text-gray-700">Career advancement opportunities</p>
        </div>
      </div>
    </section>

    <!-- Our Culture -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">Our Company Culture</h2>
      <div class="bg-blue-50 rounded-lg p-8">
        <p class="text-lg text-gray-700 mb-6">
          Arbor Care Tree Solutions is more than just a job - it's a commitment to excellence and safety. Our company culture emphasizes:
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <h3 class="text-xl font-bold mb-3">Safety First</h3>
            <p class="text-gray-700">
              We prioritize the safety of our team and our customers above all else. Every project is executed with strict safety protocols.
            </p>
          </div>
          <div>
            <h3 class="text-xl font-bold mb-3">Professional Excellence</h3>
            <p class="text-gray-700">
              We take pride in delivering high-quality work that exceeds customer expectations on every project.
            </p>
          </div>
          <div>
            <h3 class="text-xl font-bold mb-3">Team Collaboration</h3>
            <p class="text-gray-700">
              Our success depends on strong teamwork. We value communication, respect, and mutual support.
            </p>
          </div>
          <div>
            <h3 class="text-xl font-bold mb-3">Continuous Learning</h3>
            <p class="text-gray-700">
              We invest in employee development through training, certifications, and mentorship opportunities.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- How to Apply -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">How to Apply</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-white rounded-lg shadow-lg p-6">
          <div class="text-3xl font-bold text-green-600 mb-3">1</div>
          <h3 class="text-xl font-bold mb-2">Contact Us</h3>
          <p class="text-gray-700 mb-4">
            Call or email to inquire about open positions and submit your resume.
          </p>
          <a href="tel:+13039496818" class="text-green-600 hover:text-green-700 font-semibold">
            (303) 949-6818
          </a>
          <br />
          <a href="mailto:ArborCareTreeSolutions@gmail.com" class="text-green-600 hover:text-green-700 font-semibold">
            ArborCareTreeSolutions@gmail.com
          </a>
        </div>

        <div class="bg-white rounded-lg shadow-lg p-6">
          <div class="text-3xl font-bold text-green-600 mb-3">2</div>
          <h3 class="text-xl font-bold mb-2">Interview</h3>
          <p class="text-gray-700">
            We'll discuss your experience, skills, and fit with our team. Bring references and documentation of certifications.
          </p>
        </div>

        <div class="bg-white rounded-lg shadow-lg p-6">
          <div class="text-3xl font-bold text-green-600 mb-3">3</div>
          <h3 class="text-xl font-bold mb-2">Join Our Team</h3>
          <p class="text-gray-700">
            If we're a good fit, we'll discuss compensation, benefits, and start date.
          </p>
        </div>
      </div>
    </section>

    <!-- Application Materials -->
    <section class="py-12 px-4 max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8 text-center">What to Include in Your Application</h2>
      <div class="bg-gray-50 rounded-lg p-8">
        <ul class="space-y-4 text-gray-700">
          <li class="flex items-start">
            <span class="mr-4 text-2xl text-green-600">✓</span>
            <span><strong>Resume:</strong> Include your relevant experience, certifications, and previous employers</span>
          </li>
          <li class="flex items-start">
            <span class="mr-4 text-2xl text-green-600">✓</span>
            <span><strong>References:</strong> Provide 3 professional references who can speak to your work quality and reliability</span>
          </li>
          <li class="flex items-start">
            <span class="mr-4 text-2xl text-green-600">✓</span>
            <span><strong>Certifications:</strong> Copies of ISA certification, OSHA cards, or other relevant credentials</span>
          </li>
          <li class="flex items-start">
            <span class="mr-4 text-2xl text-green-600">✓</span>
            <span><strong>Driver's License:</strong> Valid Colorado or valid out-of-state driver's license</span>
          </li>
          <li class="flex items-start">
            <span class="mr-4 text-2xl text-green-600">✓</span>
            <span><strong>Cover Letter:</strong> Tell us why you'd be a great fit for Arbor Care</span>
          </li>
        </ul>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="bg-green-600 text-white py-12 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-4xl font-bold mb-4">Ready to Join Arbor Care?</h2>
        <p class="text-xl mb-8">Contact us today to discuss career opportunities.</p>
        <a href="tel:+13039496818" class="bg-white text-green-600 px-8 py-3 rounded-lg font-bold hover:bg-gray-100 transition inline-flex items-center justify-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          Call (303) 949-6818
        </a>
      </div>
    </section>
  </main>

  <Footer slot="footer" />
</Layout>
