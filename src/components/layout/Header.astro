---
import { business } from "../../data/business";

const navLinks = [
  { label: "Home", to: "/" },
  { label: "Services", to: "/tree-services" },
  { label: "Our Work", to: "/our-work" },
  { label: "Testimonials", to: "/testimonials" },
  { label: "About Us", to: "/about-arbor-care-index" },
  { label: "Contact", to: "/contact-us" },
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header class="sticky top-0 z-40">
  <!-- Top bar -->
  <div class="hidden bg-primary text-primary-foreground text-sm md:block">
    <div class="container flex items-center justify-between py-1.5">
      <span>Serving {business.address.city}, {business.address.state} &amp; Surrounding Areas</span>
      <a href={business.phoneTel} class="flex items-center gap-1.5 font-semibold hover:underline">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
        {business.phone}
      </a>
    </div>
  </div>

  <!-- Main nav -->
  <div class="border-b bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/80">
    <div class="container flex h-16 items-center justify-between">
      <a href="/" class="flex items-center">
        <img src="/assets/arborcare-logo.png" alt="Arbor Care Tree Solutions" class="h-10 w-auto" width="120" height="40" loading="eager" />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-6">
        {navLinks.map((l) => (
          <a
            href={l.to}
            class:list={[
              "text-sm font-medium transition-colors hover:text-primary",
              currentPath === l.to ? "text-primary" : "text-foreground",
            ]}
          >
            {l.label}
          </a>
        ))}
      </nav>

      <div class="hidden md:block">
        <a
          href={business.phoneTel}
          class="inline-flex items-center gap-2 rounded-md bg-primary px-5 py-2.5 text-sm font-semibold text-primary-foreground transition-colors hover:bg-primary/90"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          {business.phone}
        </a>
      </div>

      <!-- Mobile toggle -->
      <button
        id="mobile-menu-toggle"
        class="md:hidden p-2 text-foreground"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg id="menu-icon" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"></line><line x1="4" x2="20" y1="6" y2="6"></line><line x1="4" x2="20" y1="18" y2="18"></line></svg>
        <svg id="close-icon" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <nav id="mobile-menu" class="md:hidden border-t bg-background pb-4 hidden">
      {navLinks.map((l) => (
        <a
          href={l.to}
          class:list={[
            "block px-6 py-3 text-sm font-medium transition-colors hover:bg-muted",
            currentPath === l.to ? "text-primary" : "text-foreground",
          ]}
        >
          {l.label}
        </a>
      ))}
      <div class="px-6 pt-2">
        <a
          href={business.phoneTel}
          class="flex items-center justify-center gap-2 rounded-md bg-primary px-5 py-3 text-sm font-semibold text-primary-foreground"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          Call {business.phone}
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const menuIcon = document.getElementById("menu-icon");
  const closeIcon = document.getElementById("close-icon");

  toggle?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden");
    menuIcon?.classList.toggle("hidden");
    closeIcon?.classList.toggle("hidden");
    toggle.setAttribute("aria-expanded", String(!isOpen));
  });
</script>
