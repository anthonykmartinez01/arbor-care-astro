---
import { business } from "../../data/business";
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import OrganizationSchema from "../schema/OrganizationSchema.astro";
import "../../styles/global.css";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
}

const { title, description, canonical, ogImage = "/og-image.jpg" } = Astro.props;
const canonicalUrl = canonical
  ? new URL(canonical, business.siteUrl).href
  : new URL(Astro.url.pathname, business.siteUrl).href;
const ogImageUrl = new URL(ogImage, business.siteUrl).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Fonts -->
    <link rel="preload" href="/fonts/merriweather-v33-latin-regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/merriweather-v33-latin-700.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Preconnects for third-party embeds -->
    <link rel="preconnect" href="https://reputationhub.site" />
    <link rel="preconnect" href="https://go.kailenflow.com" />

    <OrganizationSchema />

    <slot name="head" />

    <!-- Google Analytics -->
    <script type="text/partytown" src={`https://www.googletagmanager.com/gtag/js?id=${business.analyticsId}`}></script>
    <script type="text/partytown" define:vars={{ analyticsId: business.analyticsId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', analyticsId);
    </script>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- Floating Call Button (mobile only) -->
    <a
      href={business.phoneTel}
      class="fixed bottom-6 right-6 z-50 flex h-14 w-14 items-center justify-center rounded-full bg-primary text-primary-foreground shadow-lg hover:bg-primary/90 transition-colors md:hidden"
      aria-label={`Call ${business.phone}`}
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
    </a>

    <!-- LeadConnector Chat Widget -->
    <script defer src={business.chatWidget.src} data-resources-url="https://beta.leadconnectorhq.com/loader.js" data-widget-id={business.chatWidget.id}></script>
  </body>
</html>
