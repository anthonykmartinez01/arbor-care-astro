---
import { business } from "../../data/business";
---

<iframe
  src={business.estimateForm}
  style="width: 100%; border: none; overflow: hidden; min-height: 600px;"
  id="inline-XjWxHG1n0SQeIqxhg944"
  data-layout="{'id':'INLINE'}"
  data-trigger-type="alwaysShow"
  data-trigger-value=""
  data-activation-type="alwaysActivated"
  data-activation-value=""
  data-deactivation-type="neverDeactivate"
  data-deactivation-value=""
  data-form-name="Free Estimate"
  data-height="600"
  data-layout-iframe-id="inline-XjWxHG1n0SQeIqxhg944"
  data-form-id="XjWxHG1n0SQeIqxhg944"
  title="Free Estimate Form"
  loading="lazy"
></iframe>

<script>
  if (!document.querySelector('script[src="https://go.kailenflow.com/js/form_embed.js"]')) {
    const s = document.createElement('script');
    s.src = 'https://go.kailenflow.com/js/form_embed.js';
    s.async = true;
    document.body.appendChild(s);
  }
</script>
