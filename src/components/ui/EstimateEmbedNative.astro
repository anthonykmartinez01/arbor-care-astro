---
import { business } from "../../data/business";
const iframeId = "inline-XjWxHG1n0SQeIqxhg944";
---

<iframe
  src={business.estimateForm}
  style="width: 100%; border: none; overflow: hidden; min-height: 600px;"
  id={iframeId}
  data-layout="{'id':'INLINE'}"
  data-trigger-type="alwaysShow"
  data-trigger-value=""
  data-activation-type="alwaysActivated"
  data-activation-value=""
  data-deactivation-type="neverDeactivate"
  data-deactivation-value=""
  data-form-name="Free Estimate"
  data-height="600"
  data-layout-iframe-id={iframeId}
  data-form-id="XjWxHG1n0SQeIqxhg944"
  title="Free Estimate Form"
  loading="lazy"
></iframe>

<script define:vars={{ estimateScript: business.estimateScript, iframeId }}>
  function loadFormEmbed() {
    if (document.querySelector(`script[src="${estimateScript}"]`)) return;
    const s = document.createElement("script");
    s.src = estimateScript;
    s.async = true;
    document.body.appendChild(s);
  }

  const iframeEl = document.getElementById(iframeId);
  if ("IntersectionObserver" in window && iframeEl) {
    const io = new IntersectionObserver(
      (entries) => {
        if (entries.some((e) => e.isIntersecting)) {
          loadFormEmbed();
          io.disconnect();
        }
      },
      { rootMargin: "300px" }
    );
    io.observe(iframeEl);
  } else {
    loadFormEmbed();
  }
</script>
