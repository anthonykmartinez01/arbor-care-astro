---
interface Props {
  className?: string;
  label?: string;
}

const { className, label = "Get Free Estimate" } = Astro.props;
---

<button class={className} data-estimate-open>
  <slot>{label}</slot>
</button>

<dialog id="estimate-dialog" class="fixed inset-0 z-50 m-auto w-full max-w-lg rounded-xl bg-background p-6 shadow-xl backdrop:bg-black/50 max-h-[90vh] overflow-y-auto">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-xl font-bold">Get Your Free Estimate</h2>
    <button data-estimate-close class="rounded-full p-1 text-foreground hover:bg-muted" aria-label="Close">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>
    </button>
  </div>
  <iframe
    id="estimate-dialog-iframe"
    data-src="https://go.kailenflow.com/widget/form/XjWxHG1n0SQeIqxhg944"
    style="width: 100%; border: none; overflow: hidden; min-height: 600px;"
    title="Free Estimate Form"
  ></iframe>
</dialog>

<script>
  const dialog = document.getElementById('estimate-dialog') as HTMLDialogElement;
  const iframe = document.getElementById('estimate-dialog-iframe') as HTMLIFrameElement;

  document.querySelectorAll<HTMLButtonElement>('[data-estimate-open]').forEach((btn) => {
    btn.addEventListener('click', () => {
      if (iframe && !iframe.src) {
        iframe.src = iframe.getAttribute('data-src') || '';
      }
      dialog?.showModal();
    });
  });

  document.querySelectorAll<HTMLButtonElement>('[data-estimate-close]').forEach((btn) => {
    btn.addEventListener('click', () => dialog?.close());
  });

  dialog?.addEventListener('click', (e) => {
    if (e.target === dialog) dialog.close();
  });
</script>
