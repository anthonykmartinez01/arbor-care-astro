---
import { business } from "../../data/business";

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": `${business.siteUrl}/#business`,
  name: business.name,
  description:
    "Professional tree services in Denver, CO including tree removal, emergency tree removal, tree trimming and pruning, tree planting, stump removal, and comprehensive tree care by ISA Certified Arborists.",
  url: business.siteUrl,
  telephone: business.phone,
  email: business.email,
  address: {
    "@type": "PostalAddress",
    streetAddress: business.address.street,
    addressLocality: business.address.city,
    addressRegion: business.address.stateAbbr,
    postalCode: business.address.zip,
    addressCountry: business.address.country,
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: Number(business.geo.lat),
    longitude: Number(business.geo.lng),
  },
  openingHours: business.openingHours,
  areaServed: business.serviceAreas.map((name) => ({ "@type": "City", name })),
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    itemListElement: [
      { "@type": "Offer", itemOffered: { "@type": "Service", name: "Tree removal" } },
      { "@type": "Offer", itemOffered: { "@type": "Service", name: "Emergency Tree Removal Service" } },
      { "@type": "Offer", itemOffered: { "@type": "Service", name: "Tree trimming & pruning" } },
      { "@type": "Offer", itemOffered: { "@type": "Service", name: "Tree planting" } },
      { "@type": "Offer", itemOffered: { "@type": "Service", name: "Tree Stump Removal & Grinding" } },
      { "@type": "Offer", itemOffered: { "@type": "Service", name: "Tree Risk Assessment" } },
      { "@type": "Offer", itemOffered: { "@type": "Service", name: "Storm Damage Tree Removal" } },
      { "@type": "Offer", itemOffered: { "@type": "Service", name: "Bush & Shrub Trimming & Removal" } },
    ],
  },
  sameAs: [
    business.socialProfiles.facebook,
    business.socialProfiles.instagram,
    business.socialProfiles.google,
  ],
  priceRange: "$$",
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
