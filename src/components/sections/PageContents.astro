---
interface TocItem {
  label: string;
  href: string;
}

interface Props {
  items: TocItem[];
  title?: string;
}

const { items, title = "What's Covered on This Page" } = Astro.props;
---

<section class="py-10 md:py-12">
  <div class="container">
    <nav aria-label="Page contents" class="mx-auto max-w-3xl rounded-lg border border-border bg-card p-6 md:p-8">
      <p class="mb-4 text-sm font-bold uppercase tracking-wider text-muted-foreground">{title}</p>
      <ul class="grid gap-x-8 gap-y-2 sm:grid-cols-2">
        {items.map((item) => (
          <li>
            <a href={item.href} class="text-sm font-medium text-primary hover:underline">
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</section>
