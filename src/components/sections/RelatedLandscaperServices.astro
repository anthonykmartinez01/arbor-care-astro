---
import { landscaperServices, LANDSCAPER_HUB } from "../../data/landscaperServices";

interface Props {
  /** Slug of the current page — excluded from the sibling list. */
  currentSlug: string;
  heading?: string;
}

const { currentSlug, heading = "Related Landscaping Services" } = Astro.props;

const links = landscaperServices.filter((s) => s.slug !== currentSlug);
---

<section class="bg-muted py-16 md:py-20">
  <div class="container">
    <div class="mx-auto mb-10 max-w-3xl text-center">
      <h2 class="text-2xl font-bold md:text-3xl">{heading}</h2>
      <p class="mt-3 text-muted-foreground">
        Explore the rest of our landscaping services across Denver and the surrounding metro.
      </p>
    </div>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {links.map((s) => (
        <a
          href={s.slug}
          class="group rounded-lg border border-border bg-background p-6 transition-all hover:border-accent/40 hover:shadow-md"
        >
          <h3 class="flex items-center justify-between text-lg font-bold transition-colors group-hover:text-primary">
            {s.title}
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-primary transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{s.blurb}</p>
        </a>
      ))}
    </div>
    <div class="mt-10 text-center">
      <a
        href={LANDSCAPER_HUB}
        class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary hover:underline"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        See all our landscaping services
      </a>
    </div>
  </div>
</section>
